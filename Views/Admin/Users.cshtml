@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Quản lý tài khoản";
    ViewData["ActiveAdminPage"] = "users";
}

<style>
    .filter-bento { background: white; border: 1px solid var(--admin-border); border-radius: var(--radius-sm); padding: 20px; margin-bottom: 24px; }
    .filter-label { font-size: 0.7rem; font-weight: 800; text-transform: uppercase; color: var(--admin-text-light); margin-bottom: 8px; display: block; letter-spacing: 0.5px; }
    .form-select-sm, .form-control-sm { border-radius: var(--radius-sm); border-color: var(--admin-border); font-weight: 600; padding: 8px 12px; }
    .form-select-sm:focus, .form-control-sm:focus { border-color: var(--admin-secondary); box-shadow: none; }
    
    .role-badge { font-size: 0.65rem; font-weight: 800; text-transform: uppercase; padding: 4px 10px; border-radius: var(--radius-sm); letter-spacing: 0.5px; }
    .role-admin { background: #0f172a; color: #fff; }
    .role-host { background: #780115; color: #fff; }
    .role-employer { background: #334155; color: #fff; }
    .role-student { background: #f1f5f9; color: #475569; }
</style>

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h3 class="fw-black mb-1">Quản lý Tài Khoản</h3>
        <p class="text-muted mb-0 small">Hệ thống quản lý người dùng và phân quyền toàn diện.</p>
    </div>
    <div class="d-flex align-items-center gap-3">
        <div class="form-check form-switch bg-white border px-3 py-2 rounded d-flex align-items-center gap-2" style="border-radius: var(--radius-sm); border-color: var(--admin-border); margin-bottom: 0;">
            <input class="form-check-input ms-0" type="checkbox" id="sysBillingToggle" style="cursor: pointer; width: 2.4rem; height: 1.2rem;">
            <label class="form-check-label fw-bold text-muted small text-uppercase" for="sysBillingToggle" id="sysBillingLabel" style="cursor: pointer; font-size: 0.7rem; letter-spacing: 0.5px; user-select: none;">THU PHÍ VIP: TẮT</label>
        </div>
        <button class="btn btn-dark fw-bold px-4" id="btnOpenCreateUser" style="background: var(--admin-secondary); border: none; font-size: 0.8rem; text-transform: uppercase; margin-bottom: 0;">
            <i class="fas fa-plus me-2"></i>Tạo tài khoản mới
        </button>
    </div>
</div>

<div class="filter-bento">
    <div class="row g-3">
        <div class="col-md-4">
            <label class="filter-label">Tìm kiếm Email</label>
            <div class="input-group input-group-sm">
                <span class="input-group-text bg-white border-end-0"><i class="fas fa-search text-muted"></i></span>
                <input type="text" class="form-control border-start-0" placeholder="user@example.com..." id="searchUser">
            </div>
        </div>
        <div class="col-md-3">
            <label class="filter-label">Vai trò</label>
            <select class="form-select form-select-sm" id="filterRole">
                <option value="">Tất cả vai trò</option>
                <option value="Admin">Quản trị viên</option>
                <option value="Host">Chủ trọ</option>
                <option value="Employer">Nhà tuyển dụng</option>
                <option value="Student">Sinh viên</option>
            </select>
        </div>
        <div class="col-md-3">
            <label class="filter-label">Trạng thái</label>
            <select class="form-select form-select-sm" id="filterStatus">
                <option value="">Tất cả trạng thái</option>
                <option value="active">Đang hoạt động</option>
                <option value="locked">Bị khóa</option>
                <option value="inactive">Đã đóng</option>
            </select>
        </div>
        <div class="col-md-2 d-flex align-items-end">
            <button class="btn btn-outline-dark fw-bold btn-sm w-100" id="btnRefreshUsers">
                <i class="fas fa-sync-alt me-2"></i>Làm mới
            </button>
        </div>
    </div>
</div>

<div class="bento-box p-0 overflow-hidden">
    <div class="table-responsive border-0">
        <table class="table table-hover align-middle mb-0">
            <thead>
                <tr>
                    <th style="width: 80px;">ID</th>
                    <th>EMAIL NGƯỜI DÙNG</th>
                    <th style="width: 150px;">VAI TRÒ</th>
                    <th style="width: 150px;">TRẠNG THÁI</th>
                    <th>LÝ DO KHÓA</th>
                    <th style="width: 160px;">NGÀY TẠO</th>
                    <th class="text-end" style="width: 120px;">THAO TÁC</th>
                </tr>
            </thead>
            <tbody id="userTableBody">
                <tr><td colspan="7" class="text-center p-5 text-muted"><i class="fas fa-spinner fa-spin me-2"></i> Đang tải dữ liệu...</td></tr>
            </tbody>
        </table>
    </div>
</div>

<div class="modal fade" id="actionReasonModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg" style="border-radius: var(--radius-sm);">
            <div class="modal-header border-0 bg-white pt-4 px-4">
                <h5 class="modal-title fw-black text-uppercase" id="actionReasonTitle" style="font-size: 1rem; letter-spacing: 0.5px;">Xác nhận hành động</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body px-4 pb-4">
                <p class="mb-3 text-muted" id="actionReasonDesc">Vui lòng nhập lý do để lưu nhật ký kiểm toán.</p>
                <input type="text" class="form-control form-control-sm" id="actionReasonInput" placeholder="Nhập lý do...">
            </div>
            <div class="modal-footer border-0 bg-light px-4 py-3">
                <button type="button" class="btn btn-sm btn-light fw-bold" data-bs-dismiss="modal">Hủy bỏ</button>
                <button type="button" class="btn btn-sm btn-dark fw-bold px-4" id="btnSubmitReason" style="background: var(--admin-secondary); border: none;">XÁC NHẬN</button>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="permanentDeleteModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg" style="border-radius: var(--radius-sm);">
            <div class="modal-header border-0 bg-danger text-white pt-4 px-4">
                <h5 class="modal-title fw-black text-uppercase" style="font-size: 1rem; letter-spacing: 0.5px;"><i class="fas fa-trash-alt me-2"></i>Xóa vĩnh viễn</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body px-4 pb-4">
                <p class="text-danger fw-bold mb-2">CẢNH BÁO: Hành động này không thể hoàn tác!</p>
                <p class="small text-muted mb-3">Xác nhận xóa vĩnh viễn tài khoản. Dữ liệu liên quan sẽ bị loại bỏ khỏi hệ thống.</p>
                <input type="text" class="form-control form-control-sm" id="permanentDeleteReasonInput" placeholder="Lý do xóa vĩnh viễn (bắt buộc)">
            </div>
            <div class="modal-footer border-0 bg-light px-4 py-3">
                <button type="button" class="btn btn-sm btn-light fw-bold" data-bs-dismiss="modal">Hủy bỏ</button>
                <button type="button" class="btn btn-sm btn-danger fw-bold px-4" id="btnPermanentDeleteConfirm">XÓA NGAY</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    let users = [];
    let currentEditingUser = null;
    let pendingAction = null;
    let pendingDeleteUserId = null;
    let actionReasonModal;
    let permanentDeleteModal;

    document.addEventListener('DOMContentLoaded', () => {
        actionReasonModal = new bootstrap.Modal(document.getElementById('actionReasonModal'));
        permanentDeleteModal = new bootstrap.Modal(document.getElementById('permanentDeleteModal'));

        document.getElementById('btnRefreshUsers').addEventListener('click', loadUsers);
        document.getElementById('searchUser').addEventListener('input', debounce(loadUsers, 300));
        document.getElementById('filterRole').addEventListener('change', loadUsers);
        document.getElementById('filterStatus').addEventListener('change', loadUsers);

        document.getElementById('btnOpenCreateUser').addEventListener('click', openCreateUserDrawer);
        document.getElementById('btnSubmitReason').addEventListener('click', submitReasonAction);
        document.getElementById('btnPermanentDeleteConfirm').addEventListener('click', submitPermanentDelete);

        document.body.addEventListener('click', function(e) {
            const btn = e.target.closest('.js-action-btn');
            if (!btn) return;
            const action = btn.getAttribute('data-action');
            if (action === 'openEditDrawer') openEditDrawer(btn.getAttribute('data-id'));
            else if (action === 'promptPermanentDelete') promptPermanentDelete(btn.getAttribute('data-id'));
            else if (action === 'closeDrawer') closeDrawer();
            else if (action === 'saveUserChanges') saveUserChanges(btn.getAttribute('data-id'));
            else if (action === 'createNewUser') createNewUser();
        });

        loadBillingStatus();
        document.getElementById('sysBillingToggle').addEventListener('change', toggleGlobalBilling);

        loadUsers();
    });

    async function loadUsers() {
        const role = document.getElementById('filterRole').value;
        const status = document.getElementById('filterStatus').value;
        const search = document.getElementById('searchUser').value.trim();

        const params = new URLSearchParams();
        if (role) params.set('role', role);
        if (search) params.set('search', search);
        if (status === 'active') params.set('isActive', 'true');
        if (status === 'inactive') params.set('isActive', 'false');
        if (status === 'locked') params.set('isLocked', 'true');

        try {
            const data = await adminFetchJson('/api/admin/users?' + params.toString());
            users = data.items || [];
            renderUsers(users);
        } catch (err) {
            showAdminToast(err.message || 'Không tải được danh sách tài khoản.', 'error');
            renderUsers([]);
        }
    }

    function renderUsers(rows) {
        const body = document.getElementById('userTableBody');
        if (!rows.length) {
            body.innerHTML = '<tr><td colspan="7" class="text-center p-5 text-muted">Không tìm thấy tài khoản nào.</td></tr>';
            return;
        }

        body.innerHTML = rows.map(x => {
            const roleBadge = roleBadgeHtml(x.role);
            const activeBadge = x.isActive
                ? '<span class="badge-status badge-active">Hoạt động</span>'
                : '<span class="badge-status badge-locked">Đã đóng</span>';
            const lockText = x.isLocked ? (x.lockedReason || 'Đã khóa') : '-';
            const verifiedBadge = x.isVerified
                ? ' <span class="verified-badge text-primary ms-1" title="Đã xác minh"><i class="fas fa-check-circle"></i></span>'
                : '';
            const vipBadge = x.isVip
                ? ' <span class="badge ms-1" style="background: #780115; color: #FFD700; border: 1px solid #FFD700; font-size: 0.6rem; font-weight: 800; padding: 2px 6px; letter-spacing: 0.5px; border-radius: 4px;">PRO</span>'
                : '';
            return `
                <tr>
                    <td class="text-muted">#${x.accountId}</td>
                    <td class="fw-bold">${escapeHtml(x.email)}${verifiedBadge}${vipBadge}</td>
                    <td>${roleBadge}</td>
                    <td>${activeBadge}${x.isLocked ? ' <span class="badge bg-danger ms-1" style="font-size: 0.6rem;">LOCKED</span>' : ''}</td>
                    <td class="small text-muted">${escapeHtml(lockText)}</td>
                    <td class="text-muted small fw-bold">${formatAdminDate(x.createdAt)}</td>
                    <td class="text-end">
                        <button class="btn btn-sm btn-outline-dark fw-bold js-action-btn" data-action="openEditDrawer" data-id="${x.accountId}" style="font-size: 0.7rem;">CHI TIẾT <i class="fas fa-chevron-right ms-1"></i></button>
                    </td>
                </tr>
            `;
        }).join('');
    }

    async function openEditDrawer(accountId) {
        try {
            const user = await adminFetchJson('/api/admin/users/' + accountId);
            currentEditingUser = user;
            const footer = `
                <button class="btn btn-outline-danger me-auto js-action-btn" data-action="promptPermanentDelete" data-id="${accountId}"><i class="fas fa-trash me-2"></i>Xóa tài khoản</button>
                <button class="btn btn-secondary js-action-btn" data-action="closeDrawer">Đóng</button>
                <button class="btn btn-primary js-action-btn" data-action="saveUserChanges" data-id="${accountId}">Lưu thay đổi</button>
            `;

            const roleLabels = {
                Host: 'Chủ trọ',
                Employer: 'Nhà tuyển dụng',
                Student: 'Sinh viên'
            };

            const roleOptions = ['Host', 'Employer', 'Student']
                .map(r => `<option value="${r}" ${user.role === r ? 'selected' : ''}>${roleLabels[r]}</option>`)
                .join('');

            const isBusinessRole = user.role === 'Host' || user.role === 'Employer';
            const isVerified = isBusinessRole && user.profile && user.profile.isVerified === true;
            const isVip = user.isVip === true;

            const verifiedSection = isBusinessRole ? `
                <div class="mb-3">
                    <label class="form-label text-muted fw-bold small text-uppercase">Xác minh tài khoản (Tích xanh)</label>
                    <div class="form-check form-switch p-0" style="margin-left: 2.5rem; display: flex; align-items: center; gap: 10px;">
                        <input class="form-check-input ms-0" type="checkbox" id="frmIsVerified" ${isVerified ? 'checked' : ''} style="cursor: pointer; width: 2.8rem; height: 1.4rem;">
                        <label class="form-check-label fw-bold ${isVerified ? 'text-primary' : 'text-muted'}" for="frmIsVerified" id="lblIsVerified" style="cursor: pointer; font-size: 0.85rem; user-select: none;">
                            ${isVerified ? 'Đã xác minh <i class="fas fa-check-circle ms-1"></i>' : 'Chưa xác minh'}
                        </label>
                    </div>
                </div>
            ` : '';

            const isBillingEnabled = document.getElementById('sysBillingToggle')?.checked;
            const vipSection = isBusinessRole ? `
                <div class="mb-3">
                    <label class="form-label text-muted fw-bold small text-uppercase">Cấp quyền VIP (Gói cước VIP)</label>
                    <div class="form-check form-switch p-0" style="margin-left: 2.5rem; display: flex; flex-direction: column; align-items: start; gap: 5px;">
                        <div style="display: flex; align-items: center; gap: 10px;">
                            <input class="form-check-input ms-0" type="checkbox" id="frmIsVip" ${isVip ? 'checked' : ''} ${isBillingEnabled ? '' : 'disabled'} style="cursor: ${isBillingEnabled ? 'pointer' : 'not-allowed'}; width: 2.8rem; height: 1.4rem;">
                            <label class="form-check-label fw-bold ${isVip ? 'text-warning' : 'text-muted'}" for="frmIsVip" id="lblIsVip" style="cursor: ${isBillingEnabled ? 'pointer' : 'not-allowed'}; font-size: 0.85rem; user-select: none; color: ${isVip ? '#e6b800' : ''};">
                                ${isVip ? 'VIP Hoạt động <i class="fas fa-crown ms-1" style="color:#FFD700;"></i>' : 'Chưa kích hoạt'}
                            </label>
                        </div>
                        ${isBillingEnabled ? '' : '<span class="text-danger small fw-bold" style="font-size: 0.72rem; margin-top: 2px;"><i class="fas fa-info-circle me-1"></i>Vui lòng BẬT "THU PHÍ VIP" toàn cục trước để tùy chỉnh</span>'}
                    </div>
                </div>
            ` : '';

            const html = `
                <form id="drawerUserForm">
                    <div class="mb-3">
                        <label class="form-label text-muted fw-bold small text-uppercase">Email</label>
                        <input type="email" class="form-control" id="frmEmail" value="${escapeHtml(user.email)}" ${user.role === 'Admin' ? 'disabled' : ''}>
                    </div>
                    <div class="row mb-3">
                        <div class="col-6">
                            <label class="form-label text-muted fw-bold small text-uppercase">Vai trò</label>
                            <select class="form-select" id="frmRole" ${user.role === 'Admin' ? 'disabled' : ''}>
                                    ${user.role === 'Admin' ? '<option value="Admin" selected>Quản trị viên</option>' : roleOptions}
                            </select>
                        </div>
                        <div class="col-6">
                            <label class="form-label text-muted fw-bold small text-uppercase">Trạng thái hoạt động</label>
                            <select class="form-select" id="frmIsActive" ${user.role === 'Admin' ? 'disabled' : ''}>
                                <option value="1" ${user.isActive ? 'selected' : ''}>1 - Hoạt động</option>
                                <option value="0" ${!user.isActive ? 'selected' : ''}>0 - Ngừng hoạt động</option>
                            </select>
                        </div>
                    </div>
                    ${verifiedSection}
                    ${vipSection}
                    <div class="mb-3">
                        <label class="form-label text-muted fw-bold small text-uppercase">Khóa tài khoản</label>
                        <select class="form-select" id="frmIsLocked" ${user.role === 'Admin' ? 'disabled' : ''}>
                            <option value="0" ${!user.isLocked ? 'selected' : ''}>Mở khóa</option>
                            <option value="1" ${user.isLocked ? 'selected' : ''}>Khóa</option>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label text-muted fw-bold small text-uppercase">Lý do khóa</label>
                        <input type="text" class="form-control" id="frmLockedReason" value="${escapeHtml(user.lockedReason || '')}" ${user.role === 'Admin' ? 'disabled' : ''}>
                    </div>
                    <div class="alert alert-secondary mb-0">
                        <div><strong>Lần đăng nhập cuối:</strong> ${formatAdminDate(user.lastLoginAt)}</div>
                    </div>
                </form>
            `;

            openDrawer('Chi tiết tài khoản #' + accountId, html, footer);

            if (isBusinessRole) {
                setTimeout(() => {
                    const chk = document.getElementById('frmIsVerified');
                    if (chk) {
                        chk.addEventListener('change', function() {
                            const lbl = document.getElementById('lblIsVerified');
                            if (this.checked) {
                                lbl.innerHTML = 'Đã xác minh <i class="fas fa-check-circle ms-1"></i>';
                                lbl.classList.remove('text-muted');
                                lbl.classList.add('text-primary');
                            } else {
                                lbl.innerHTML = 'Chưa xác minh';
                                lbl.classList.remove('text-primary');
                                lbl.classList.add('text-muted');
                            }
                        });
                    }
                    const vchk = document.getElementById('frmIsVip');
                    if (vchk) {
                        vchk.addEventListener('change', async function() {
                            const lbl = document.getElementById('lblIsVip');
                            try {
                                const res = await adminFetchJson(`/api/admin/users/${accountId}/toggle-vip`, { method: 'POST' });
                                const active = res.isVip;
                                this.checked = active;
                                if (active) {
                                    lbl.innerHTML = 'VIP Hoạt động <i class="fas fa-crown ms-1" style="color:#FFD700;"></i>';
                                    lbl.style.color = '#e6b800';
                                    lbl.classList.remove('text-muted');
                                    lbl.classList.add('text-warning');
                                    showAdminToast('Đã cấp quyền VIP cho tài khoản.', 'success');
                                } else {
                                    lbl.innerHTML = 'Chưa kích hoạt';
                                    lbl.style.color = '';
                                    lbl.classList.remove('text-warning');
                                    lbl.classList.add('text-muted');
                                    showAdminToast('Đã hủy quyền VIP của tài khoản.', 'success');
                                }
                                await loadUsers();
                            } catch (err) {
                                this.checked = !this.checked;
                                showAdminToast(err.message || 'Không thể thay đổi trạng thái VIP.', 'error');
                            }
                        });
                    }
                }, 50);
            }
        } catch (err) {
            showAdminToast(err.message || 'Không tải được chi tiết tài khoản.', 'error');
        }
    }

    function openCreateUserDrawer() {
        const html = `
            <form id="drawerCreateForm">
                <div class="mb-3">
                    <label class="form-label text-muted fw-bold small text-uppercase">Email</label>
                    <input type="email" class="form-control" id="createEmail" placeholder="user@domain.com">
                </div>
                <div class="mb-3">
                    <label class="form-label text-muted fw-bold small text-uppercase">Password tạm</label>
                    <input type="password" class="form-control" id="createPassword" placeholder="Mật khẩu tạm">
                </div>
                <div class="mb-3">
                    <label class="form-label text-muted fw-bold small text-uppercase">Vai trò</label>
                    <select class="form-select" id="createRole">
                        <option value="Student">Sinh viên</option>
                        <option value="Host">Chủ trọ</option>
                        <option value="Employer">Nhà tuyển dụng</option>
                    </select>
                </div>
            </form>
        `;

        const footer = `
            <button class="btn btn-secondary js-action-btn" data-action="closeDrawer">Hủy</button>
            <button class="btn btn-success js-action-btn" data-action="createNewUser"><i class="fas fa-plus me-2"></i>Tạo User</button>
        `;

        openDrawer('Tạo tài khoản mới', html, footer);
    }

    async function createNewUser() {
        const email = document.getElementById('createEmail').value.trim();
        const password = document.getElementById('createPassword').value;
        const role = document.getElementById('createRole').value;

        if (!email || !password) {
            showAdminToast('Email và mật khẩu là bắt buộc.', 'error');
            return;
        }

        try {
            await adminFetchJson('/api/admin/users', {
                method: 'POST',
                body: JSON.stringify({ email, password, role, reason: 'Create by admin UI' })
            });
            closeDrawer();
            showAdminToast('Tạo tài khoản thành công.', 'success');
            await loadUsers();
        } catch (err) {
            showAdminToast(err.message || 'Tạo tài khoản thất bại.', 'error');
        }
    }

    function saveUserChanges(accountId) {
        pendingAction = async (reason) => {
            const email = document.getElementById('frmEmail').value.trim();
            const role = document.getElementById('frmRole').value;
            const isActive = document.getElementById('frmIsActive').value === '1';
            const isLocked = document.getElementById('frmIsLocked').value === '1';
            const lockedReason = document.getElementById('frmLockedReason').value.trim();

            if (!currentEditingUser) {
                throw new Error('Thiếu dữ liệu phiên chỉnh sửa.');
            }

            const bodyData = { email, isActive, isLocked, lockedReason, reason };
            const chkVerified = document.getElementById('frmIsVerified');
            if (chkVerified) {
                bodyData.isVerified = chkVerified.checked;
            }

            await adminFetchJson('/api/admin/users/' + accountId, {
                method: 'PUT',
                body: JSON.stringify(bodyData)
            });

            if (currentEditingUser.role !== 'Admin' && role !== currentEditingUser.role) {
                await adminFetchJson('/api/admin/users/' + accountId + '/role', {
                    method: 'PATCH',
                    body: JSON.stringify({ newRole: role, reason })
                });
            }

            closeDrawer();
            showAdminToast('Đã lưu thay đổi tài khoản.', 'success');
            await loadUsers();
        };

        document.getElementById('actionReasonTitle').innerHTML = '<i class="fas fa-user-tag me-2"></i>Lưu thay đổi tài khoản';
        document.getElementById('actionReasonDesc').innerText = 'Nhập lý do để lưu nhật ký kiểm toán.';
        document.getElementById('actionReasonInput').value = '';
        actionReasonModal.show();
    }

    function promptPermanentDelete(accountId) {
        pendingDeleteUserId = accountId;
        document.getElementById('permanentDeleteReasonInput').value = '';
        permanentDeleteModal.show();
    }

    async function submitPermanentDelete() {
        if (!pendingDeleteUserId) return;

        const reason = document.getElementById('permanentDeleteReasonInput').value.trim();
        if (!reason || !reason.trim()) {
            showAdminToast('Bắt buộc nhập lý do xóa vĩnh viễn.', 'error');
            return;
        }

        try {
            await adminFetchJson('/api/admin/users/' + pendingDeleteUserId, {
                method: 'DELETE',
                body: JSON.stringify({ reason: reason.trim() })
            });

            permanentDeleteModal.hide();
            closeDrawer();
            showAdminToast('Đã xóa vĩnh viễn tài khoản.', 'success');
            await loadUsers();
        } catch (err) {
            showAdminToast(err.message || 'Xóa vĩnh viễn thất bại.', 'error');
        }
    }

    async function submitReasonAction() {
        const reason = document.getElementById('actionReasonInput').value.trim();
        if (!reason) {
            showAdminToast('Bắt buộc nhập lý do.', 'error');
            return;
        }

        const action = pendingAction;
        pendingAction = null;
        actionReasonModal.hide();

        try {
            if (action) await action(reason);
        } catch (err) {
            showAdminToast(err.message || 'Hành động thất bại.', 'error');
        }
    }

    function roleBadgeHtml(role) {
        if (role === 'Admin') return '<span class="badge bg-dark">Quản trị</span>';
        if (role === 'Host') return '<span class="badge bg-primary">Chủ trọ</span>';
        if (role === 'Employer') return '<span class="badge bg-secondary">Nhà tuyển dụng</span>';
        return '<span class="badge bg-info text-dark">Sinh viên</span>';
    }

    function escapeHtml(input) {
        return String(input)
            .replaceAll('&', '&amp;')
            .replaceAll('<', '&lt;')
            .replaceAll('>', '&gt;')
            .replaceAll('"', '&quot;')
            .replaceAll("'", '&#39;');
    }

    function debounce(fn, wait) {
        let t = null;
        return function (...args) {
            if (t) clearTimeout(t);
            t = setTimeout(() => fn.apply(this, args), wait);
        };
    }

    async function loadBillingStatus() {
        try {
            const res = await adminFetchJson('/api/admin/users/billing-status');
            const toggle = document.getElementById('sysBillingToggle');
            const lbl = document.getElementById('sysBillingLabel');
            toggle.checked = res.enabled;
            if (res.enabled) {
                lbl.innerHTML = 'THU PHÍ VIP: BẬT <i class="fas fa-dollar-sign text-success ms-1"></i>';
                lbl.classList.remove('text-muted');
                lbl.classList.add('text-danger');
            } else {
                lbl.innerHTML = 'THU PHÍ VIP: TẮT';
                lbl.classList.remove('text-danger');
                lbl.classList.add('text-muted');
            }
        } catch (err) {
            console.error('Lỗi khi tải cấu hình billing:', err);
        }
    }

    async function toggleGlobalBilling() {
        const toggle = this;
        const lbl = document.getElementById('sysBillingLabel');
        const originalState = !toggle.checked;
        const targetState = toggle.checked;

        try {
            const res = await adminFetchJson('/api/admin/users/billing-toggle', {
                method: 'POST',
                body: JSON.stringify({ enabled: targetState })
            });
            toggle.checked = res.enabled;
            if (res.enabled) {
                lbl.innerHTML = 'THU PHÍ VIP: BẬT <i class="fas fa-dollar-sign text-success ms-1"></i>';
                lbl.classList.remove('text-muted');
                lbl.classList.add('text-danger');
                showAdminToast('Đã BẬT cơ chế bắt buộc thanh toán VIP.', 'success');
            } else {
                lbl.innerHTML = 'THU PHÍ VIP: TẮT';
                lbl.classList.remove('text-danger');
                lbl.classList.add('text-muted');
                showAdminToast('Đã TẮT cơ chế bắt buộc thanh toán VIP (miễn phí thử nghiệm).', 'success');
            }
        } catch (err) {
            toggle.checked = originalState; // revert
            showAdminToast(err.message || 'Không thể cập nhật cấu hình hệ thống.', 'error');
        }
    }
</script>
}
