@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Dọn dữ liệu";
    ViewData["ActiveAdminPage"] = "cleanup";
}

<style>
    :root {
        --brand-primary: #780115;
        --brand-secondary: #f7b638;
        --bg-surface: #ffffff;
        --text-main: #1e293b;
        --text-muted: #64748b;
        --border-soft: #e2e8f0;
        --shadow-bento: 0 4px 20px rgba(0,0,0,0.04);
        --radius-bento: 24px;
    }
    
    .bento-grid { display: grid; grid-template-columns: repeat(12, 1fr); gap: 20px; margin-bottom: 24px; }
    
    .bento-card {
        background: var(--bg-surface);
        border: 1px solid var(--border-soft);
        border-radius: var(--radius-bento);
        padding: 24px;
        box-shadow: var(--shadow-bento);
        transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1), box-shadow 0.3s;
        display: flex;
        flex-direction: column;
    }
    .bento-card:hover { transform: translateY(-4px); box-shadow: 0 12px 30px rgba(120, 1, 21, 0.08); border-color: rgba(120, 1, 21, 0.2); }

    .bento-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px; }
    .bento-title { font-weight: 800; font-size: 0.85rem; text-transform: uppercase; letter-spacing: 1px; color: var(--text-muted); display: flex; align-items: center; gap: 10px; margin: 0; }

    .icon-box { width: 38px; height: 38px; border-radius: 12px; display: flex; align-items: center; justify-content: center; font-size: 1.1rem; }
    .icon-primary { background: #78011515; color: var(--brand-primary); }
    .icon-warning { background: #f7b63815; color: var(--brand-secondary); }
    .icon-success { background: #10b98115; color: #10b981; }
    .icon-danger { background: #ef444415; color: #ef4444; }
    .icon-info { background: #3b82f615; color: #3b82f6; }

    .span-12 { grid-column: span 12; }
    .span-8 { grid-column: span 8; }
    .span-4 { grid-column: span 4; }
    .span-6 { grid-column: span 6; }
    .span-3 { grid-column: span 3; }

    @@media (max-width: 1200px) { .span-4, .span-8 { grid-column: span 12; } }

    .table-custom th { border-bottom: 2px solid var(--border-soft); color: var(--text-muted); font-weight: 700; font-size: 0.75rem; text-transform: uppercase; padding-top: 0;}
    .table-custom td { padding: 14px 12px; border-bottom: 1px solid var(--border-soft); vertical-align: middle; font-size: 0.9rem;}
    .table-custom tr:last-child td { border-bottom: none; }
    .stat-row:hover { background: #f8fafc; }

    .cleanup-btn-group { display: grid; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); gap: 12px; }
    .cleanup-btn { text-align: left; padding: 14px 16px; border-radius: 12px; font-size: 0.85rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.5px; transition: all 0.2s; border: 1px solid var(--border-soft); background: white; color: var(--text-main); display: flex; align-items: center; }
    .cleanup-btn i { width: 24px; margin-right: 10px; font-size: 1.1rem; color: var(--brand-secondary); text-align: center; }
    .cleanup-btn:hover { border-color: var(--brand-secondary); color: var(--brand-secondary); background: #fefce8; transform: translateY(-2px); box-shadow: 0 4px 12px rgba(247, 182, 56, 0.15); }
    
    .cleanup-btn.btn-danger-action { border-color: #fee2e2; color: #b91c1c; }
    .cleanup-btn.btn-danger-action i { color: #ef4444; }
    .cleanup-btn.btn-danger-action:hover { background: #fef2f2; border-color: #ef4444; color: #b91c1c; box-shadow: 0 4px 12px rgba(239, 68, 68, 0.15); }

    .cleanup-btn.btn-primary-action i { color: var(--brand-primary); }
    .cleanup-btn.btn-primary-action:hover { border-color: var(--brand-primary); color: var(--brand-primary); background: #fff1f2; box-shadow: 0 4px 12px rgba(120, 1, 21, 0.15); }
</style>

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="fw-black mb-1" style="color: var(--text-main);">Dọn Dẹp Dữ Liệu</h2>
        <p class="text-muted mb-0">Công cụ bảo trì định kỳ và tối ưu bộ nhớ đám mây</p>
    </div>
    <button type="button" class="btn btn-outline-dark fw-bold px-4" style="border-radius: 12px;" onclick="loadCleanupStats()">
        <i class="fas fa-sync-alt me-2"></i> Làm mới
    </button>
</div>

<div class="bento-grid">
    <!-- Cột Thống kê -->
    <div class="bento-card span-8">
        <div class="bento-header">
            <h3 class="bento-title"><div class="icon-box icon-info"><i class="fas fa-chart-pie"></i></div> Thống Kê Rác</h3>
        </div>
        
        <div class="table-responsive flex-grow-1">
            <table class="table table-custom mb-0">
                <thead>
                    <tr>
                        <th class="ps-2">Loại Dữ Liệu</th>
                        <th class="text-end">Tổng Bản Ghi</th>
                        <th class="text-end pe-2">Có Thể Xóa</th>
                    </tr>
                </thead>
                <tbody id="cleanupStatsBody">
                    <tr><td colspan="3" class="text-center p-5 text-muted"><i class="fas fa-spinner fa-spin me-2"></i> Đang tính toán dữ liệu...</td></tr>
                </tbody>
            </table>
        </div>
    </div>

    <!-- Cột Thông tin & Hành động nhanh -->
    <div class="span-4" style="display: flex; flex-direction: column; gap: 20px;">
        <div class="bento-card" style="padding: 20px; flex-grow: 0;">
            <div class="d-flex gap-3">
                <div class="flex-shrink-0"><div class="icon-box icon-primary"><i class="fas fa-shield-alt"></i></div></div>
                <div>
                    <h6 class="fw-bold mb-1" style="color: var(--brand-primary);">An toàn dữ liệu</h6>
                    <p class="text-muted small mb-0" style="line-height: 1.4;">Dọn dẹp Audit Logs, Orphan Media (Cloudinary), Ghost Accounts giúp tối ưu Cloud và DB, không ảnh hưởng đến trải nghiệm người dùng hiện tại.</p>
                </div>
            </div>
        </div>

        <div class="bento-card" style="padding: 20px; flex-grow: 1; justify-content: center; background: linear-gradient(135deg, var(--brand-primary), #a30e25); border: none;">
            <div class="text-center text-white">
                <i class="fas fa-rocket fa-3x mb-3" style="opacity: 0.9;"></i>
                <h4 class="fw-bold mb-2">Tối ưu toàn diện</h4>
                <p class="small mb-4" style="opacity: 0.8;">Khuyên dùng định kỳ mỗi tháng</p>
                <button type="button" class="btn btn-light fw-bold px-4 py-2 text-uppercase" style="border-radius: 12px; color: var(--brand-primary); letter-spacing: 1px;" onclick="runCleanupPreset('all')">
                    Dọn Sạch Hệ Thống
                </button>
            </div>
        </div>
    </div>

    <!-- Cột Bảng Điều Khiển -->
    <div class="bento-card span-12">
        <div class="bento-header">
            <h3 class="bento-title"><div class="icon-box icon-warning"><i class="fas fa-sliders-h"></i></div> Công Cụ Dọn Dẹp</h3>
        </div>
        
        <div class="cleanup-btn-group">
            <button type="button" class="cleanup-btn" onclick="runCleanupPreset('light')">
                <i class="fas fa-leaf"></i>Dọn cơ bản
            </button>
            <button type="button" class="cleanup-btn" onclick="runCleanupPreset('logs')">
                <i class="fas fa-terminal"></i>Xóa System Logs
            </button>
            <button type="button" class="cleanup-btn" onclick="runCleanupPreset('notifications')">
                <i class="fas fa-bell"></i>Xóa thông báo đã đọc
            </button>
            <button type="button" class="cleanup-btn" onclick="runCleanupPreset('handled')">
                <i class="fas fa-check-double"></i>Xóa hồ sơ đã xử lý
            </button>
            <button type="button" class="cleanup-btn btn-primary-action" onclick="runCleanupPreset('orphans')">
                <i class="fas fa-link-slash"></i>Xóa Media (Cloudinary)
            </button>
            <button type="button" class="cleanup-btn btn-danger-action" onclick="runCleanupPreset('chat')">
                <i class="fas fa-comments"></i>Xóa toàn bộ Chat
            </button>
        </div>

        <div id="cleanupFeedback" class="small mt-4 p-3 rounded fw-bold" style="display: none; border-radius: 12px !important;"></div>
    </div>
    <!-- Cột Kiểm Định Dữ Liệu -->
    <div class="bento-card span-12 mt-2" style="background: #f8fafc;">
        <div class="bento-header">
            <h3 class="bento-title"><div class="icon-box icon-success"><i class="fas fa-stethoscope"></i></div> Kiểm Định Tính Toàn Vẹn (Data Integrity)</h3>
            <button type="button" class="btn btn-success fw-bold px-4" style="border-radius: 12px;" onclick="runDataAudit()">
                <i class="fas fa-search me-2"></i> Chạy Kiểm Định 1,600+ Bản Ghi
            </button>
        </div>
        
        <p class="text-muted small mb-3">Script này sẽ quét toàn bộ cơ sở dữ liệu để tìm các lỗi logic (tọa độ lỗi, ảnh chết, dữ liệu mồ côi) sau khi di chuyển dữ liệu.</p>
        
        <div id="auditResults" style="display: none;">
            <div id="auditSummary" class="alert alert-info mb-0" style="border-radius: 12px; border: none; background: #e0f2fe; color: #0369a1;">
                <i class="fas fa-info-circle me-2"></i> Đang phân tích dữ liệu...
            </div>
            <div id="auditDetails" class="mt-3 p-3 bg-white border rounded" style="border-radius: 12px; font-family: monospace; font-size: 0.85rem; max-height: 200px; overflow-y: auto;"></div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    document.addEventListener('DOMContentLoaded', () => {
        loadCleanupStats();
    });

    async function loadCleanupStats() {
        const body = document.getElementById('cleanupStatsBody');
        if (!body) return;

        body.innerHTML = '<tr><td colspan="3" class="text-center p-5 text-muted"><i class="fas fa-spinner fa-spin me-2"></i> Đang tải thống kê...</td></tr>';

        try {
            const stats = await adminFetchJson('/api/admin/cleanup/stats');
            const rows = [
                { label: 'Tài khoản mờ (Ghost Accounts) > 1 năm', total: '-', orphan: stats.ghostAccounts, isWarning: true },
                { label: 'Bài đăng rác (Expired Posts) > 30 ngày', total: '-', orphan: stats.expiredPosts, isWarning: true },
                { label: 'Tệp tin phương tiện (Media Cloudinary)', total: stats.mediaTotal, orphan: stats.mediaOrphan, isDanger: true },
                { label: 'Nhật ký kiểm toán (Audit Logs)', total: stats.adminAuditLogsTotal, orphan: stats.adminAuditLogsTotal },
                { label: 'Nhật ký hệ thống (System Logs)', total: stats.systemLogsTotal, orphan: stats.systemLogsTotal },
                { label: 'Thông báo người dùng', total: stats.notificationsTotal, orphan: stats.notificationsRead },
                { label: 'Hồ sơ ứng tuyển việc làm', total: stats.jobApplicationsTotal, orphan: stats.jobApplicationsHandled },
                { label: 'Lịch hẹn xem phòng', total: stats.appointmentsTotal, orphan: stats.appointmentsHandled },
                { label: 'Vị trí bản đồ (Locations)', total: stats.locationsTotal, orphan: stats.locationsOrphan },
                { label: 'Tin nhắn hội thoại', total: stats.messagesTotal, orphan: stats.messagesTotal },
                { label: 'Cuộc trò chuyện', total: stats.conversationsTotal, orphan: stats.conversationsTotal }
            ];

            body.innerHTML = rows.map(r => {
                const badgeClass = r.isDanger ? 'text-danger fw-black' : (r.isWarning ? 'text-warning fw-bold' : 'text-danger fw-bold');
                return `
                <tr class="stat-row">
                    <td class="ps-2 py-3 fw-bold text-muted" style="font-size: 0.85rem;"><i class="fas fa-caret-right me-2" style="color:var(--border-soft);"></i>${r.label}</td>
                    <td class="text-end py-3 fw-bold">${r.total !== '-' ? Number(r.total || 0).toLocaleString() : '-'}</td>
                    <td class="text-end py-3 pe-2 ${badgeClass}">${Number(r.orphan || 0).toLocaleString()}</td>
                </tr>
                `;
            }).join('');
        } catch (err) {
            body.innerHTML = `<tr><td colspan="3" class="text-center p-5 text-danger fw-bold">${escapeHtml(err.message || 'Không tải được thống kê')}</td></tr>`;
        }
    }

    async function runCleanupPreset(mode) {
        const feedback = document.getElementById('cleanupFeedback');
        if (!feedback) return;

        const confirmText = window.prompt('Hành động này sẽ xóa vĩnh viễn dữ liệu (Bao gồm dữ liệu trên Cloudinary). Nhập "CONFIRM" để xác nhận:');
        if (confirmText !== 'CONFIRM') {
            showAdminToast('Đã hủy thao tác.', 'info');
            return;
        }

        const isLight = mode === 'light';
        const isStrong = mode === 'strong' || mode === 'all';

        const payload = {
            deleteReadNotifications: mode === 'notifications' || isLight || isStrong,
            deleteHandledJobApplications: mode === 'handled' || isStrong,
            deleteHandledAppointments: mode === 'handled' || isStrong,
            deleteAllChatData: mode === 'chat' || isStrong,
            deleteEmptyConversations: mode !== 'chat' && !isStrong,
            deleteSystemLogs: mode === 'logs' || isLight || isStrong,
            deleteAdminAuditLogs: mode === 'logs' || isLight || isStrong,
            deleteOrphanMedia: mode === 'orphans' || isStrong,
            deleteOrphanLocations: mode === 'orphans' || isStrong
        };

        feedback.style.display = 'block';
        feedback.className = 'small text-muted mt-4 p-3 rounded fw-bold border';
        feedback.innerHTML = '<i class="fas fa-broom fa-spin me-2"></i> Đang thực hiện dọn dẹp, vui lòng chờ...';

        try {
            const result = await adminFetchJson('/api/admin/cleanup/purge', {
                method: 'POST',
                body: JSON.stringify(payload)
            });

            const deleted = result?.deleted || {};
            const summary = `
                <div class="d-flex align-items-center mb-2"><i class="fas fa-check-circle fs-5 me-2"></i><strong style="font-size:1rem;">Kết quả dọn dẹp thành công:</strong></div>
                <ul class="mb-0" style="list-style-type:square; padding-left: 20px;">
                    <li><strong>Media (Cloudinary) & Location:</strong> ${(deleted.deletedOrphanMedia ?? 0) + (deleted.deletedOrphanLocations ?? 0)} tệp rác đã bị hủy.</li>
                    <li><strong>Thông báo đã đọc:</strong> ${deleted.deletedReadNotifications ?? 0}</li>
                    <li><strong>Hồ sơ ứng tuyển & Lịch hẹn:</strong> ${(deleted.deletedHandledJobApplications ?? 0) + (deleted.deletedHandledAppointments ?? 0)}</li>
                    <li><strong>Logs (System/Audit):</strong> ${(deleted.deletedSystemLogs ?? 0) + (deleted.deletedAdminAuditLogs ?? 0)}</li>
                    <li><strong>Tin nhắn & Hội thoại:</strong> ${deleted.deletedMessages ?? 0} tin nhắn trong ${deleted.deletedConversations ?? 0} cuộc hội thoại.</li>
                </ul>
            `;
            
            feedback.className = 'small text-success mt-4 p-4 bg-success bg-opacity-10 border border-success border-opacity-20 rounded';
            feedback.innerHTML = summary;

            showAdminToast('Hệ thống đã được dọn dẹp sạch sẽ.', 'success');
            await loadCleanupStats();
        } catch (err) {
            feedback.className = 'small text-danger mt-4 p-4 bg-danger bg-opacity-10 border border-danger border-opacity-20 rounded';
            feedback.innerHTML = '<i class="fas fa-exclamation-triangle me-2"></i>' + (err.message || 'Dọn dữ liệu thất bại.');
            showAdminToast('Có lỗi xảy ra trong quá trình dọn dẹp.', 'error');
        }
    }

    async function runDataAudit() {
        const resultsDiv = document.getElementById('auditResults');
        const summaryDiv = document.getElementById('auditSummary');
        const detailsDiv = document.getElementById('auditDetails');
        
        resultsDiv.style.display = 'block';
        summaryDiv.className = 'alert alert-info mb-0';
        summaryDiv.innerHTML = '<i class="fas fa-spinner fa-spin me-2"></i> Đang quét toàn bộ hệ thống...';
        detailsDiv.innerHTML = '';

        try {
            const result = await adminFetchJson('/api/admin/cleanup/audit-integrity', { method: 'POST' });
            
            if (result.issuesFound === 0) {
                summaryDiv.className = 'alert alert-success mb-0';
                summaryDiv.innerHTML = '<i class="fas fa-check-circle me-2"></i> Tuyệt vời! Hệ thống hoàn toàn sạch sẽ, không phát hiện lỗi logic dữ liệu nào.';
                detailsDiv.innerHTML = '<li>[OK] Đã kiểm tra 5 chỉ mục quan trọng.</li>';
            } else {
                summaryDiv.className = 'alert alert-warning mb-0';
                summaryDiv.innerHTML = `<i class="fas fa-exclamation-triangle me-2"></i> Phát hiện ${result.issuesFound} vấn đề cần lưu ý trong 1,600+ bản ghi.`;
                detailsDiv.innerHTML = result.details.map(d => `<div class="mb-1 text-danger">- ${d}</div>`).join('');
            }
            showAdminToast('Kiểm định hoàn tất.', 'success');
        } catch (err) {
            summaryDiv.className = 'alert alert-danger mb-0';
            summaryDiv.innerHTML = '<i class="fas fa-times-circle me-2"></i> Lỗi khi chạy kiểm định: ' + err.message;
            showAdminToast('Lỗi kiểm định.', 'error');
        }
    }

    function escapeHtml(input) {
        if (!input) return '';
        return String(input)
            .replaceAll('&', '&amp;')
            .replaceAll('<', '&lt;')
            .replaceAll('>', '&gt;')
            .replaceAll('"', '&quot;')
            .replaceAll("'", '&#39;');
    }
</script>
}
