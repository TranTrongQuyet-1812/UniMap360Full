@using System.Security.Claims
@{
    /* ── Bootstrap Auth Data (passed from _Layout.cshtml via ViewData) ── */
    var principal = User ?? new ClaimsPrincipal();
    int? bootstrapAccountId = null;
    if (int.TryParse(principal.FindFirstValue(ClaimTypes.NameIdentifier), out var parsedAccountId))
    {
        bootstrapAccountId = parsedAccountId;
    }

    var bootstrapAuth = new
    {
        isAuthenticated = principal.Identity?.IsAuthenticated == true,
        accountId = bootstrapAccountId,
        email = principal.FindFirstValue(ClaimTypes.Email) ?? principal.FindFirstValue("email"),
        role = principal.FindFirstValue(ClaimTypes.Role) ?? principal.FindFirstValue("role")
    };

    var displayEmail = bootstrapAuth.email ?? "";
    var displayClaimsName = principal.FindFirstValue(ClaimTypes.Name) 
                            ?? principal.FindFirstValue("name") 
                            ?? principal.FindFirstValue("unique_name");
    var displayName = !string.IsNullOrEmpty(displayClaimsName) 
                      ? displayClaimsName 
                      : (!string.IsNullOrEmpty(displayEmail) ? displayEmail.Split('@')[0] : "Tài khoản");
    var displayAvatar = principal.FindFirstValue("avatarUrl") ?? principal.FindFirstValue("avatar");
    var displayRole = "Thành viên";
    if (bootstrapAuth.isAuthenticated && !string.IsNullOrEmpty(bootstrapAuth.role))
    {
        switch (bootstrapAuth.role.ToLower())
        {
            case "admin":
                displayRole = "Quản trị viên";
                break;
            case "student":
                displayRole = "Sinh viên";
                break;
            case "host":
                displayRole = "Chủ trọ";
                break;
            case "employer":
                displayRole = "Nhà tuyển dụng";
                break;
            default:
                displayRole = "Người dùng";
                break;
        }
    }
}

