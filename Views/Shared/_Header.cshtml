                                    <img id="nav-auth-user-avatar" src="@(string.IsNullOrEmpty(displayAvatar) ? "https://api.dicebear.com/7.x/identicon/svg?seed=User" : displayAvatar)" class="rounded-circle me-2" style="width: 38px; height: 38px; object-fit: cover; border: 2px solid rgba(255,255,255,0.5); box-shadow: 0 2px 5px rgba(0,0,0,0.2);" alt="Avatar">
                                    <div class="text-start d-flex flex-column">
                                        <span id="nav-auth-user-name" class="fw-800 text-truncate" style="max-width: 140px; font-size: 0.95rem; line-height: 1.2;">@displayName</span>
                                        <span class="small fw-600 text-muted" style="font-size: 0.7rem;">@displayRole</span>
                                    </div>
                                </div>
                                <i class="fas fa-chevron-down ms-3" style="font-size: 0.8rem;"></i>
                            </div>
                            
                        </button>
                        <script>
                            (function () {
                                try {
                                    const raw = localStorage.getItem("unimap360.account");
                                    if (raw) {
                                        const account = JSON.parse(raw);
                                        if (account && account.email) {
                                            const nameEl = document.getElementById("nav-auth-user-name");
                                            const avatarEl = document.getElementById("nav-auth-user-avatar");
                                            if (account.fullName && nameEl) {
                                                nameEl.textContent = account.fullName;
                                            }
                                            if (account.avatarUrl && avatarEl) {
                                                avatarEl.src = account.avatarUrl;
                                            }
                                        }
                                    }
                                } catch (_) {}
                            })();
                        </script>
