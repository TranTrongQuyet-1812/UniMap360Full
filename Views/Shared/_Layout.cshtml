@using System.Security.Claims
@using System.Text.Json
@{
    var principal = User ?? new ClaimsPrincipal();
    int? bootstrapAccountId = null;
    if (int.TryParse(principal.FindFirstValue(ClaimTypes.NameIdentifier), out var parsedAccountId))
    {
        bootstrapAccountId = parsedAccountId;
    }

    var bootstrapAuth = new
    {
        isAuthenticated = principal.Identity?.IsAuthenticated == true,
        accountId = bootstrapAccountId,
        email = principal.FindFirstValue(ClaimTypes.Email) ?? principal.FindFirstValue("email"),
        role = principal.FindFirstValue(ClaimTypes.Role) ?? principal.FindFirstValue("role"),
        fullName = principal.Identity?.IsAuthenticated == true ? (principal.FindFirstValue(ClaimTypes.Name) ?? principal.FindFirstValue("name") ?? principal.FindFirstValue("unique_name")) : null,
        avatarUrl = principal.Identity?.IsAuthenticated == true ? (principal.FindFirstValue("avatarUrl") ?? principal.FindFirstValue("avatar")) : null
    };
    var bootstrapAuthJson = JsonSerializer.Serialize(bootstrapAuth);
}
<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - UniMap360</title>
    <link class="favicon" rel="icon" type="image/png" href="/img/UniMap360_Logo.png" />

    <!-- SEO Meta Tags -->
    <meta name="description" content="@(ViewData["MetaDescription"] ?? "Nền tảng bản đồ thông minh kết nối sinh viên, chủ trọ và nhà tuyển dụng. Tìm kiếm phòng trọ, việc làm và ở ghép tại Tp. Hồ Chí Minh.")" />
    <meta name="keywords" content="UniMap360, tìm phòng trọ, việc làm sinh viên, ở ghép, bản đồ sinh viên, Thủ Đức, làng đại học" />
    <link rel="canonical" href="@(ViewData["CanonicalUrl"] ?? Context.Request.Scheme + "://" + Context.Request.Host + Context.Request.Path)" />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content="@(Context.Request.Scheme + "://" + Context.Request.Host + Context.Request.Path)" />
    <meta property="og:title" content="@(ViewData["Title"] ?? "UniMap360 - Bản đồ kết nối sinh viên")" />
    <meta property="og:description" content="@(ViewData["MetaDescription"] ?? "Nền tảng bản đồ thông minh kết nối sinh viên, chủ trọ và nhà tuyển dụng.")" />
    <meta property="og:image" content="@(ViewData["MetaImage"] ?? Context.Request.Scheme + "://" + Context.Request.Host + "/img/UniMap360_Logo.png")" />

    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:title" content="@(ViewData["Title"] ?? "UniMap360 - Bản đồ kết nối sinh viên")" />
    <meta property="twitter:description" content="@(ViewData["MetaDescription"] ?? "Nền tảng bản đồ thông minh kết nối sinh viên, chủ trọ và nhà tuyển dụng.")" />
    <meta property="twitter:image" content="@(ViewData["MetaImage"] ?? Context.Request.Scheme + "://" + Context.Request.Host + "/img/UniMap360_Logo.png")" />

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/chat-widget.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/responsive.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/UniMap360.styles.css" asp-append-version="true" />
    <!-- Leaflet & FontAwesome -->
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY=" crossorigin="" />
    <link rel="stylesheet" href="https://unpkg.com/leaflet.markercluster@1.5.3/dist/MarkerCluster.css" integrity="sha384-pmjIAcz2bAn0xukfxADbZIb3t8oRT9Sv0rvO+BR5Csr6Dhqq+nZs59P0pPKQJkEV" crossorigin="anonymous" />
    <link rel="stylesheet" href="https://unpkg.com/leaflet.markercluster@1.5.3/dist/MarkerCluster.Default.css" integrity="sha384-wgw+aLYNQ7dlhK47ZPK7FRACiq7ROZwgFNg0m04avm4CaXS+Z9Y7nMu8yNjBKYC+" crossorigin="anonymous" />
    <link rel="stylesheet" href="~/css/luxury-header.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" integrity="sha384-iw3OoTErCYJJB9mCa8LNS2hbsQ7M3C0EpIsO/H5+EGAkPGc6rk+V8i04oW/K5xq0" crossorigin="anonymous" referrerpolicy="no-referrer" />

    <!-- Google Analytics (GA4) - Replace G-XXXXXXXXXX with actual ID -->
    <environment exclude="Development">
        <script async src="https://www.googletagmanager.com/gtag/js?id=G-XXXXXXXXXX" crossorigin="anonymous"></script>
        <script>
          window.dataLayer = window.dataLayer || [];
          function gtag(){dataLayer.push(arguments);}
          gtag('js', new Date());
          gtag('config', 'G-XXXXXXXXXX');
        </script>
    </environment>
</head>

<body>
    <script>
        window.__UNIMAP360_AUTH_BOOTSTRAP__ = @Html.Raw(bootstrapAuthJson);
    </script>

    @* ══════════════════════════════════════════════════════════════════
       HEADER - Partial View (Views/Shared/_Header.cshtml)
       ══════════════════════════════════════════════════════════════════ *@
    @await Html.PartialAsync("_Header")

    @if (ViewData["IsMapPage"] is bool isMapPage && isMapPage)
    {
        <!-- Map Page doesn't use container, and needs to drop down 70px -->
        <main role="main" class="app-map-main w-100 position-relative">
            @RenderBody()
        </main>
    }
    else
    {
        <!-- Other pages use padding to clear the 70px fixed header. Container can be fluid or normal -->
        <div class="app-page-main-wrap">
            <main role="main" class="pb-3">
                @RenderBody()
            </main>
        </div>
        
        @* ══════════════════════════════════════════════════════════════════
           FOOTER - Partial View (Views/Shared/_Footer.cshtml)
           ══════════════════════════════════════════════════════════════════ *@
        @await Html.PartialAsync("_Footer")
    }

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo=" crossorigin=""></script>
    <script src="https://unpkg.com/leaflet.markercluster@1.5.3/dist/leaflet.markercluster.js" integrity="sha384-eXVCORTRlv4FUUgS/xmOyr66XBVraen8ATNLMESp92FKXLAMiKkerixTiBvXriZr" crossorigin="anonymous"></script>
    <script src="~/js/unimap-core.js" asp-append-version="true"></script>
    <script src="~/js/auth-store.js" asp-append-version="true"></script>
    <script src="~/js/api-client.js" asp-append-version="true"></script>
    <script src="~/js/vendor/signalr.min.js" asp-append-version="true"></script>
    <script src="~/js/realtime-client.js" asp-append-version="true"></script>
    <script src="~/js/navbar-auth.js" asp-append-version="true"></script>
    <script src="~/js/notification-center.js" asp-append-version="true"></script>
    <script src="~/js/listing-map-utils.js" asp-append-version="true"></script>
    <script src="~/js/chat-widget.js" asp-append-version="true"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>

</html>
