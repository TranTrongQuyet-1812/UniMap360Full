            <div class="mb-3">
                <label class="form-label small fw-800 text-muted text-uppercase mb-1" style="letter-spacing: 0.5px; font-size: 0.65rem;">Email liên hệ</label>
                <input type="email" id="detail-job-apply-email" class="form-control rounded-3 border-2" style="font-size: 0.95rem;" placeholder="example@gmail.com">
            </div>
            <div class="mb-3">
                <label class="form-label small fw-800 text-muted text-uppercase mb-1" style="letter-spacing: 0.5px; font-size: 0.65rem;">Số điện thoại</label>
                <input type="text" id="detail-job-apply-phone" class="form-control rounded-3 border-2" style="font-size: 0.95rem;" placeholder="0987xxxxxx">
            </div>
            <div class="mb-3">
                <label class="form-label small fw-800 text-muted text-uppercase mb-1" style="letter-spacing: 0.5px; font-size: 0.65rem;">Link CV (Google Drive/Dropbox...)</label>
                <input type="text" id="detail-job-apply-cv-url" class="form-control rounded-3 border-2" style="font-size: 0.95rem;" placeholder="https://drive.google.com/...">
            </div>
            <div class="mb-4">
                <label class="form-label small fw-800 text-muted text-uppercase mb-1" style="letter-spacing: 0.5px; font-size: 0.65rem;">Hoặc tải file CV (.pdf, .doc)</label>
                <input type="file" id="detail-job-apply-cv-file" class="form-control rounded-3 border-2" style="font-size: 0.9rem;">
            </div>
            
            <div id="detail-job-apply-feedback" class="small mb-3 text-center"></div>
            
            <div class="d-flex gap-3">
                <button id="detail-job-apply-cancel" class="btn btn-light flex-grow-1 fw-bold py-2 rounded-pill">Hủy</button>
                <button id="detail-job-apply-submit" class="btn btn-primary flex-grow-1 fw-bold py-2 rounded-pill shadow-sm">Gửi ứng tuyển</button>
            </div>

            <div class="mt-4 p-3 rounded-3 bg-light border border-dashed text-center">
                <p class="small text-muted mb-0" style="font-size: 0.75rem;">Thông tin của bạn sẽ được bảo mật và gửi trực tiếp đến nhà tuyển dụng.</p>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/pages/detail.js" asp-append-version="true"></script>
}






