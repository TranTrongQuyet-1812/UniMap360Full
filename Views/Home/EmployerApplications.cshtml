@{
    ViewData["Title"] = "Hồ sơ ứng tuyển";
}

<style>
    .employer-applications-page {
        min-height: calc(100vh - var(--app-nav-height, 70px));
        background: var(--color-bg);
        padding: 32px 0;
    }
    .employer-applications-header {
        margin-bottom: 16px;
    }
    .employer-applications-header h2 {
        margin: 0;
        font-weight: 800;
    }
    .employer-applications-header p {
        margin: 4px 0 0;
        color: var(--color-text-muted);
    }
    .employer-applications-toolbar {
        background: #fff;
        border-radius: 12px;
        border: 1px solid var(--color-border);
        box-shadow: var(--shadow-card);
        padding: 14px;
        display: grid;
        grid-template-columns: 220px 220px 1fr auto;
        gap: 10px;
        margin-bottom: 8px;
        transition: box-shadow var(--motion-base) var(--ease-cinematic), border-color var(--motion-base) var(--ease-cinematic);
    }
    .employer-applications-toolbar:focus-within {
        border-color: var(--color-border-dark);
        box-shadow: var(--shadow-float);
    }
    .applications-stats {
        display: grid;
        grid-template-columns: repeat(4, minmax(0, 1fr));
        gap: 10px;
        margin-bottom: 12px;
    }
    .stat-card {
        background: #fff;
        border: 1px solid var(--color-border);
        border-radius: 12px;
        padding: 10px 12px;
        box-shadow: var(--shadow-card);
    }
    .stat-card .label {
        font-size: 0.82rem;
        color: var(--color-text-muted);
    }
    .stat-card .value {
        font-size: 1.25rem;
        font-weight: 800;
        color: var(--color-primary);
        line-height: 1.2;
    }
    .realtime-status {
        margin: 0 2px 12px;
        font-size: 0.88rem;
        color: var(--color-text-muted);
    }
    .realtime-status.is-error { color: #dc3545; }
    .realtime-status.is-syncing { color: #0d6efd; }
    .applications-list {
        display: flex;
        flex-direction: column;
        gap: 12px;
    }
    .application-card {
        background: #fff;
        border: 1px solid var(--color-border);
        border-radius: 14px;
        box-shadow: var(--shadow-card);
        padding: 16px;
        transition: transform var(--motion-fast) var(--ease-cinematic), box-shadow var(--motion-base) var(--ease-cinematic);
    }
    .application-card:hover {
        transform: translateY(-2px);
        box-shadow: var(--shadow-float);
    }
    .application-top {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 10px;
        margin-bottom: 8px;
    }
    .application-title {
        font-weight: 700;
        margin-bottom: 2px;
    }
    .application-sub {
        color: var(--color-text-muted);
        font-size: 0.92rem;
    }
    .application-grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 8px 16px;
        margin: 10px 0 12px;
    }
    .application-grid .label {
        color: var(--color-text-muted);
        font-size: 0.82rem;
    }
    .application-grid .value {
        font-weight: 600;
    }
    .application-actions {
        display: flex;
        gap: 8px;
        flex-wrap: wrap;
    }
    .empty-box {
        background: #fff;
        border: 1px dashed var(--color-border-dark);
        border-radius: 14px;
        padding: 40px 20px;
        text-align: center;
        color: var(--color-text-muted);
    }
    .toast-msg {
        position: fixed;
        top: 90px;
        right: 20px;
        padding: 12px 20px;
        border-radius: 10px;
        color: #fff;
        font-weight: 600;
        z-index: 5600;
        opacity: 0;
        transform: translateX(30px);
        transition: all .3s ease;
    }
    .toast-msg.show {
        opacity: 1;
        transform: translateX(0);
    }
    .toast-msg.success { background: #198754; }
    .toast-msg.error { background: #dc3545; }

    @@media (max-width: 992px) {
        .employer-applications-toolbar {
            grid-template-columns: 1fr;
        }
        .applications-stats {
            grid-template-columns: repeat(2, minmax(0, 1fr));
        }
        .application-grid {
            grid-template-columns: 1fr;
        }
    }
</style>

<div class="employer-applications-page">
    <div class="container">
        <div class="employer-applications-header">
            <h2>Hồ sơ ứng tuyển</h2>
            <p>Xem và xử lý hồ sơ ứng tuyển của ứng viên theo thời gian thực.</p>
        </div>

        <div class="employer-applications-toolbar">
            <select id="statusFilter" class="form-select">
                <option value="">Tất cả trạng thái</option>
                <option value="Pending">Đang chờ</option>
                <option value="Accepted">Đã chấp nhận</option>
                <option value="Rejected">Đã từ chối</option>
            </select>
            <select id="cvFilter" class="form-select">
                <option value="">CV: Tất cả</option>
                <option value="has">CV: Đã có</option>
                <option value="missing">CV: Chưa có</option>
            </select>
            <input id="searchInput" type="text" class="form-control" placeholder="Tìm theo tên công việc / tên ứng viên..." />
            <button id="reloadBtn" type="button" class="btn btn-outline-secondary">Tải lại</button>
        </div>

        <div class="applications-stats">
            <div class="stat-card">
                <div class="label">Tổng hồ sơ</div>
                <div class="value" id="stat-total">0</div>
            </div>
            <div class="stat-card">
                <div class="label">Đang chờ</div>
                <div class="value" id="stat-pending">0</div>
            </div>
            <div class="stat-card">
                <div class="label">Đã chấp nhận</div>
                <div class="value" id="stat-accepted">0</div>
            </div>
            <div class="stat-card">
                <div class="label">Đã từ chối</div>
                <div class="value" id="stat-rejected">0</div>
            </div>
        </div>

        <div id="realtimeStatus" class="realtime-status">Đang chuẩn bị đồng bộ realtime...</div>

        <div id="listWrap" class="applications-list">
            <div class="empty-box"><i class="fas fa-spinner fa-spin me-2"></i>Đang tải dữ liệu...</div>
        </div>
    </div>
</div>

<div class="toast-msg" id="toastMsg"></div>

@section Scripts {
<script>
    (function () {
        const listWrap = document.getElementById('listWrap');
        const statusFilter = document.getElementById('statusFilter');
        const cvFilter = document.getElementById('cvFilter');
        const searchInput = document.getElementById('searchInput');
        const reloadBtn = document.getElementById('reloadBtn');
        const realtimeStatus = document.getElementById('realtimeStatus');
        const toast = document.getElementById('toastMsg');
        const statTotal = document.getElementById('stat-total');
        const statPending = document.getElementById('stat-pending');
        const statAccepted = document.getElementById('stat-accepted');
        const statRejected = document.getElementById('stat-rejected');

        let allItems = [];
        let isLoading = false;
        let autoRefreshTimer = null;
        let lastDataSignature = '';
        const autoRefreshMs = 15000;



        function setRealtimeStatus(message, tone) {
            if (!realtimeStatus) return;
            realtimeStatus.textContent = message;
            realtimeStatus.classList.remove('is-error', 'is-syncing');
            if (tone === 'error') realtimeStatus.classList.add('is-error');
            if (tone === 'syncing') realtimeStatus.classList.add('is-syncing');
        }

        function formatClock(value) {
            const d = value instanceof Date ? value : new Date(value);
            if (Number.isNaN(d.getTime())) return '--:--:--';
            return d.toLocaleTimeString('vi-VN');
        }

        function getAuthAccount() {
            return window.UniMap360AuthStore?.getStoredAccount?.() || null;
        }

        function isEmployerAccount(account) {
            return String(account?.role || '').toLowerCase() === 'employer';
        }

        function statusBadge(status) {
            const normalized = (status || '').toLowerCase();
            if (normalized === 'accepted') return '<span class="badge bg-success-subtle text-success">Đã chấp nhận</span>';
            if (normalized === 'rejected') return '<span class="badge bg-danger-subtle text-danger">Đã từ chối</span>';
            return '<span class="badge bg-secondary-subtle text-secondary-emphasis">Đang chờ</span>';
        }

        function canHandle(status) {
            return (status || '').toLowerCase() === 'pending';
        }

        function escapeHtml(input) {
            return (input || '').toString()
                .replaceAll('&', '&amp;')
                .replaceAll('<', '&lt;')
                .replaceAll('>', '&gt;')
                .replaceAll('"', '&quot;')
                .replaceAll("'", '&#039;');
        }

        function buildDataSignature(items) {
            if (!Array.isArray(items)) return '';
            return JSON.stringify(items.map(function (item) {
                return [item.applicationId, item.status];
            }));
        }

        function updateStats(items) {
            const source = Array.isArray(items) ? items : [];
            statTotal.textContent = String(source.length);
            statPending.textContent = String(source.filter(x => (x.status || '').toLowerCase() === 'pending').length);
            statAccepted.textContent = String(source.filter(x => (x.status || '').toLowerCase() === 'accepted').length);
            statRejected.textContent = String(source.filter(x => (x.status || '').toLowerCase() === 'rejected').length);
        }

        function render() {
            const keyword = (searchInput.value || '').trim().toLowerCase();
            const selectedStatus = statusFilter.value;
            const selectedCv = cvFilter.value;

            const filtered = allItems.filter(function (item) {
                if (selectedStatus && item.status !== selectedStatus) return false;
                if (selectedCv === 'has' && !item.cvUrl) return false;
                if (selectedCv === 'missing' && item.cvUrl) return false;
                if (!keyword) return true;

                const jobTitle = (item.jobTitle || '').toLowerCase();
                const studentName = (item.studentName || '').toLowerCase();
                const email = (item.studentEmail || '').toLowerCase();
                return jobTitle.includes(keyword) || studentName.includes(keyword) || email.includes(keyword);
            });

            if (!filtered.length) {
                listWrap.innerHTML = '<div class="empty-box"><i class="fas fa-inbox me-2"></i>Không có hồ sơ nào phù hợp.</div>';
                return;
            }

            listWrap.innerHTML = filtered.map(function (item) {
                const cvLink = item.cvUrl
                    ? `<div class="d-flex flex-wrap gap-2">
                            <a href="/api/job-applications/${item.applicationId}/cv" target="_blank" rel="noopener">Xem CV</a>
                            <a href="/api/job-applications/${item.applicationId}/cv/download" target="_blank" rel="noopener">Tải CV</a>
                       </div>`
                    : 'Chưa cập nhật';

                const actionButtons = canHandle(item.status)
                    ? `
                        <button class="btn btn-success btn-sm js-action-btn" data-action="accept" data-id="${item.applicationId}">
                            <i class="fas fa-check me-1"></i>Chấp nhận
                        </button>
                        <button class="btn btn-outline-danger btn-sm js-action-btn" data-action="reject" data-id="${item.applicationId}">
                            <i class="fas fa-xmark me-1"></i>Từ chối
                        </button>
                      `
                    : '<span class="small text-muted">Hồ sơ đã được xử lý.</span>';

                const chatButton = item.studentAccountId
                    ? `
                        <button class="btn btn-outline-primary btn-sm js-chat-btn" data-account-id="${item.studentAccountId}" data-name="${escapeHtml(item.studentName || '')}">
                            <i class="fas fa-comment-alt me-1"></i>Nhắn tin
                        </button>
                      `
                    : '';

                return `
                    <div class="application-card">
                        <div class="application-top">
                            <div>
                                <div class="application-title">${escapeHtml(item.jobTitle || 'Công việc')}</div>
                                <div class="application-sub">Ứng viên: ${escapeHtml(item.studentName || 'Không rõ')} (${escapeHtml(item.studentEmail || 'Không có email')})</div>
                            </div>
                            ${statusBadge(item.status)}
                        </div>
                        <div class="application-grid">
                            <div>
                                <div class="label">Trường / Chuyên ngành</div>
                                <div class="value">${escapeHtml(item.studentUniversity || 'Chưa cập nhật')} / ${escapeHtml(item.studentMajor || 'Chưa cập nhật')}</div>
                            </div>
                            <div>
                                <div class="label">Email liên hệ</div>
                                <div class="value">${escapeHtml(item.contactEmail || item.studentEmail || 'Chưa cập nhật')}</div>
                            </div>
                            <div>
                                <div class="label">Số điện thoại liên hệ</div>
                                <div class="value">${escapeHtml(item.contactPhone || 'Chưa cập nhật')}</div>
                            </div>
                            <div>
                                <div class="label">CV</div>
                                <div class="value">${cvLink}</div>
                            </div>
                            <div>
                                <div class="label">Mã ứng viên</div>
                                <div class="value">${item.studentId ?? '-'}</div>
                            </div>
                            <div>
                                <div class="label">Mã hồ sơ</div>
                                <div class="value">${item.applicationId}</div>
                            </div>
                        </div>
                        <div class="application-actions">
                            ${chatButton}
                            ${actionButtons}
                        </div>
                    </div>
                `;
            }).join('');

            listWrap.querySelectorAll('.js-action-btn').forEach(function (button) {
                button.addEventListener('click', function () {
                    const applicationId = Number(button.dataset.id);
                    const action = button.dataset.action;
                    handleAction(applicationId, action, button);
                });
            });

            listWrap.querySelectorAll('.js-chat-btn').forEach(function (button) {
                button.addEventListener('click', function () {
                    const accountId = Number(button.dataset.accountId);
                    const name = button.dataset.name;
                    openDirectChat(accountId, name);
                });
            });
        }

        function openDirectChat(targetAccountId, name) {
            const chatApi = window.UniMap360ChatWidget;
            if (!chatApi || typeof chatApi.openDirectChat !== 'function') {
                alert('Không mở được hộp chat. Vui lòng tải lại trang hoặc đăng nhập lại.');
                return;
            }
            Promise.resolve(chatApi.openDirectChat(targetAccountId, name)).catch((err) => {
                alert(err?.message || 'Không mở được đoạn chat.');
            });
        }

        async function loadData(options) {
            const opts = options || {};
            const silent = opts.silent === true;
            if (isLoading) return;

            const token = getToken();
            const account = getAuthAccount();
            if (!token || !isEmployerAccount(account)) {
                listWrap.innerHTML = '<div class="empty-box"><i class="fas fa-lock me-2"></i>Trang này chỉ dành cho tài khoản Nhà tuyển dụng đã đăng nhập.</div>';
                setRealtimeStatus('Trang này chỉ dành cho tài khoản Nhà tuyển dụng đã đăng nhập.', 'error');
                return;
            }

            isLoading = true;
            reloadBtn.disabled = true;

            if (!silent) {
                listWrap.innerHTML = '<div class="empty-box"><i class="fas fa-spinner fa-spin me-2"></i>Đang tải dữ liệu...</div>';
            } else {
                setRealtimeStatus('Đang tự động đồng bộ...', 'syncing');
            }

            try {
                const response = await fetch('/api/employer/job-applications?limit=200', {
                    credentials: 'same-origin'
                });

                let data = await response.json();
                if (data && data.success === true && data.data !== undefined) {
                    data = data.data;
                }
                if (!response.ok) {
                    throw new Error(data?.message || 'Không tải được danh sách hồ sơ.');
                }

                const items = Array.isArray(data.items) ? data.items : [];
                const signature = buildDataSignature(items);
                const hasChanged = signature !== lastDataSignature;

                allItems = items;
                updateStats(allItems);
                if (hasChanged || !silent) render();
                lastDataSignature = signature;

                setRealtimeStatus(`Tự động cập nhật mỗi ${Math.round(autoRefreshMs / 1000)} giây. Lần cuối: ${formatClock(new Date())}`, null);
            } catch (error) {
                if (!silent) {
                    listWrap.innerHTML = `<div class="empty-box text-danger">${escapeHtml(error?.message || 'Không tải được danh sách.')}</div>`;
                }
                setRealtimeStatus(error?.message || 'Không tải được danh sách.', 'error');
            } finally {
                isLoading = false;
                reloadBtn.disabled = false;
            }
        }

        async function handleAction(applicationId, action, sourceButton) {
            const token = getToken();
            if (!token) {
                showToast('Vui lòng đăng nhập lại.', 'error');
                return;
            }

            const actionText = action === 'accept' ? 'chấp nhận' : 'từ chối';
            const confirmed = window.confirm(`Bạn chắc chắn muốn ${actionText} hồ sơ này?`);
            if (!confirmed) return;

            const endpoint = action === 'accept'
                ? `/api/employer/job-applications/${applicationId}/accept`
                : `/api/employer/job-applications/${applicationId}/reject`;

            sourceButton.disabled = true;

            try {
                const response = await fetch(endpoint, {
                    method: 'POST',
                    credentials: 'same-origin'
                });

                let data = await response.json();
                if (data && data.success === true && data.data !== undefined) {
                    data = data.data;
                }
                if (!response.ok) {
                    throw new Error(data?.message || 'Xử lý hồ sơ thất bại.');
                }

                showToast(data?.message || 'Cập nhật thành công.', 'success');
                await loadData({ silent: false });
            } catch (error) {
                showToast(error?.message || 'Có lỗi xảy ra.', 'error');
                sourceButton.disabled = false;
            }
        }

        function startAutoRefresh() {
            if (autoRefreshTimer) clearInterval(autoRefreshTimer);
            autoRefreshTimer = setInterval(function () {
                if (document.hidden) return;
                loadData({ silent: true });
            }, autoRefreshMs);
        }

        statusFilter.addEventListener('change', render);
        cvFilter.addEventListener('change', render);
        searchInput.addEventListener('input', render);
        reloadBtn.addEventListener('click', function () { loadData({ silent: false }); });
        document.addEventListener('visibilitychange', function () {
            if (!document.hidden) loadData({ silent: true });
        });
        window.addEventListener('beforeunload', function () {
            if (autoRefreshTimer) clearInterval(autoRefreshTimer);
        });

        loadData({ silent: false });
        startAutoRefresh();
    })();
</script>
}
