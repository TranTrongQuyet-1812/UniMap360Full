@{
    ViewData["Title"] = "Đăng tin việc làm";
}

<style>
    .post-page-wrapper {
        min-height: calc(100vh - var(--app-nav-height, 70px));
        background-color: var(--color-bg);
        padding: 40px 0;
    }

    .post-card {
        background: #fff;
        border-radius: 16px;
        border: 1px solid var(--color-border);
        box-shadow: var(--shadow-float);
        padding: 50px;
        max-width: 820px;
        margin: 0 auto;
    }

    .post-card-header {
        display: flex;
        align-items: center;
        gap: 15px;
        margin-bottom: 35px;
        padding-bottom: 20px;
        border-bottom: 2px solid var(--color-border);
    }

    .post-card-header .icon-box {
        width: 50px;
        height: 50px;
        border-radius: 12px;
        background: var(--color-primary);
        display: flex;
        align-items: center;
        justify-content: center;
        color: #fff;
        font-size: 1.3rem;
    }

    .post-card-header h2 {
        font-weight: 800;
        color: var(--color-text);
        margin: 0;
    }

    .post-card-header p {
        margin: 0;
        font-size: 0.9rem;
        color: var(--color-text-muted);
    }

    .form-label-custom {
        font-weight: 700;
        font-size: 0.9rem;
        color: var(--color-text);
        margin-bottom: 6px;
        display: block;
    }

    .form-label-custom .required {
        color: #dc3545;
        margin-left: 3px;
    }

    .form-input {
        width: 100%;
        padding: 13px 18px;
        border: 2px solid var(--color-border);
        border-radius: 10px;
        outline: none;
        transition: all 0.25s;
        font-weight: 500;
        background: #fafafa;
    }

    .form-input:focus {
        border-color: var(--color-primary);
        background: #fff;
        box-shadow: 0 0 0 3px rgba(128,0,0,0.06);
    }

    .form-input::placeholder {
        color: #b0b0b0;
    }

    .form-row {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 20px;
        margin-bottom: 22px;
    }

    .form-group {
        margin-bottom: 22px;
    }

    .post-submit-btn {
        width: 100%;
        padding: 16px;
        background: var(--color-primary);
        color: #fff;
        border: none;
        border-radius: 12px;
        font-size: 1.1rem;
        font-weight: bold;
        cursor: pointer;
        transition: all 0.3s;
        margin-top: 10px;
    }

    .post-submit-btn:hover {
        background: #6a0000;
        transform: translateY(-2px);
        box-shadow: 0 8px 20px rgba(128,0,0,0.15);
    }

    .post-submit-btn:disabled {
        opacity: 0.6;
        cursor: not-allowed;
        transform: none;
    }

    .toast-msg {
        position: fixed;
        top: 90px;
        right: 20px;
        padding: 16px 28px;
        border-radius: 10px;
        color: #fff;
        font-weight: 600;
        z-index: 5600;
        opacity: 0;
        transform: translateX(40px);
        transition: all 0.4s;
        box-shadow: 0 8px 20px rgba(0,0,0,0.15);
    }

    .toast-msg.show {
        opacity: 1;
        transform: translateX(0);
    }

    .toast-msg.success { background: #198754; }
    .toast-msg.error { background: #dc3545; }

    .char-count {
        font-size: 0.78rem;
        color: #aaa;
        text-align: right;
        margin-top: 4px;
    }

    .map-pin-box {
        border: 2px solid var(--color-border);
        border-radius: 12px;
        background: #fafafa;
        padding: 14px;
    }

    .map-pin-actions {
        display: flex;
        gap: 10px;
        margin-bottom: 10px;
        flex-wrap: wrap;
    }

    .map-pin-btn {
        border: none;
        border-radius: 8px;
        padding: 9px 14px;
        font-weight: 700;
        cursor: pointer;
    }

    .map-pin-btn.primary {
        background: #0d6efd;
        color: #fff;
    }

    .map-pin-btn.secondary {
        background: #6c757d;
        color: #fff;
    }

    .map-pin-status {
        font-size: 0.84rem;
        color: #374151;
        margin-bottom: 8px;
    }

    .map-pin-canvas {
        height: 280px;
        border-radius: 10px;
        overflow: hidden;
        border: 1px solid #d4d9df;
        background: #e5e7eb;
    }

    @@media (max-width: 768px) {
        .form-row { grid-template-columns: 1fr; }
        .post-card { padding: 30px 20px; margin: 0 15px; }
    }
</style>

<div class="post-page-wrapper">
    <div class="container">
        <div class="post-card">

            <div class="post-card-header">
                <div class="icon-box"><i class="fas fa-briefcase"></i></div>
                <div>
                    <h2>Đăng tin việc làm</h2>
                    <p>Điền đầy đủ thông tin bên dưới để đăng tin tuyển dụng lên UniMap360</p>
                </div>
            </div>

            <form id="postJobForm">
                <input type="hidden" name="LocationId" value="0">

                <!-- Hàng 1: Danh mục + Tỉnh/Thành -->
                <div class="form-row">
                    <div>
                        <label class="form-label-custom">Danh mục <span class="required">*</span></label>
                        <select id="jobCategorySelect" name="CategoryId" class="form-input" required>
                            <option value="">— Chọn danh mục —</option>
                        </select>
                    </div>
                    <div>
                        <label class="form-label-custom">Tỉnh/Thành phố <span class="required">*</span></label>
                        <select id="provinceSelect" name="ProvinceCode" class="form-input" required>
                            <option value="">— Chọn tỉnh/thành —</option>
                        </select>
                        <input id="provinceNameInput" type="hidden" name="ProvinceName" value="">
                    </div>
                </div>

                <!-- Hàng 2: Quận/Huyện + Phường/Xã -->
                <div class="form-row">
                    <div>
                        <label class="form-label-custom">Quận/Huyện <span class="required">*</span></label>
                        <select id="districtSelect" name="DistrictCode" class="form-input" required disabled>
                            <option value="">— Chọn quận/huyện —</option>
                        </select>
                        <input id="districtNameInput" type="hidden" name="DistrictName" value="">
                    </div>
                    <div>
                        <label class="form-label-custom">Phường/Xã</label>
                        <select id="wardSelect" name="WardCode" class="form-input" disabled>
                            <option value="">— Chọn phường/xã —</option>
                        </select>
                        <input id="wardNameInput" type="hidden" name="WardName" value="">
                    </div>
                </div>

                <!-- Hàng 3: Số nhà + Đường -->
                <div class="form-row">
                    <div>
                        <label class="form-label-custom">Số nhà</label>
                        <input type="text" id="houseNumberInput" name="HouseNumber" class="form-input" placeholder="VD: 25/7A">
                    </div>
                    <div>
                        <label class="form-label-custom">Đường</label>
                        <input type="text" id="streetInput" name="Street" class="form-input" placeholder="VD: Nguyễn Trãi">
                    </div>
                </div>

                <div class="form-group">
                    <label class="form-label-custom">Ghim vị trí bản đồ <span class="required">*</span></label>
                    <div class="map-pin-box">
                        <div class="map-pin-actions">
                            <button id="geocodeBtn" type="button" class="map-pin-btn primary">Ghim từ địa chỉ</button>
                            <button id="useCurrentLocationBtn" type="button" class="map-pin-btn primary">Lấy vị trí của tôi</button>
                            <button id="resetPinBtn" type="button" class="map-pin-btn secondary">Đặt lại ghim</button>
                        </div>
                        <div class="map-pin-status" id="mapPinStatus">Chưa có vị trí. Hãy chọn địa chỉ và bấm Ghim từ địa chỉ.</div>
                        <div id="jobPinMap" class="map-pin-canvas"></div>
                        <div class="form-row" style="margin-top: 10px; margin-bottom: 0;">
                            <div>
                                <label class="form-label-custom">Latitude</label>
                                <input id="latitudeInput" type="text" name="Latitude" class="form-input" readonly>
                            </div>
                            <div>
                                <label class="form-label-custom">Longitude</label>
                                <input id="longitudeInput" type="text" name="Longitude" class="form-input" readonly>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Hàng 4: Tên công việc -->
                <div class="form-group">
                    <label class="form-label-custom">Tên công việc <span class="required">*</span></label>
                    <input type="text" name="JobTitle" class="form-input" placeholder="VD: Tuyển nhân viên phục vụ quán cà phê gần ĐH Bách khoa" required maxlength="255" oninput="updateCharCount(this, 'titleCount', 255)">
                    <div class="char-count" id="titleCount">0 / 255</div>
                </div>

                <!-- Hàng 5: Mức lương + Loại hình -->
                <div class="form-row">
                    <div>
                        <label class="form-label-custom">Mức lương</label>
                        <input type="text" name="SalaryRange" class="form-input" placeholder="VD: 3-5 triệu/tháng (Bỏ trống = Thỏa thuận)" maxlength="100">
                    </div>
                    <div>
                        <label class="form-label-custom">Loại hình công việc</label>
                        <select name="JobType" class="form-input">
                            <option value="">Mặc định (Part-time)</option>
                            <option value="Part-time">Part-time</option>
                            <option value="Full-time">Full-time</option>
                            <option value="Freelance">Freelance</option>
                            <option value="Internship">Thực tập</option>
                        </select>
                    </div>
                </div>

                <!-- Hàng 6: SĐT + Trạng thái -->
                <div class="form-row">
                    <div>
                        <label class="form-label-custom">Số điện thoại liên hệ</label>
                        <input type="tel" name="ContactPhone" class="form-input" placeholder="VD: 0901234567" maxlength="20">
                    </div>
                    <div>
                        <label class="form-label-custom">Trạng thái</label>
                        <select name="JobStatus" class="form-input">
                            <option value="">Mặc định (Đang tuyển)</option>
                            <option value="Open">Đang tuyển</option>
                            <option value="Closed">Đã đóng</option>
                        </select>
                    </div>
                </div>

                <!-- Hàng 7: Mô tả -->
                <div class="form-group">
                    <label class="form-label-custom">Mô tả chi tiết</label>
                    <textarea name="Description" class="form-input" rows="5" placeholder="Mô tả yêu cầu công việc, thời gian làm, quyền lợi, địa chỉ cụ thể..."></textarea>
                </div>

                <button type="submit" class="post-submit-btn" id="submitBtn">
                    <i class="fas fa-paper-plane me-2"></i> Đăng Tin Ngay
                </button>
            </form>

        </div>
    </div>
</div>

<div class="toast-msg" id="toastMsg"></div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11.26.25/dist/sweetalert2.all.min.js" integrity="sha384-nLoOnA/BDh8A/jxqtckg4DumuCGOBYUnNJLZdQz/zfYNp3wcjGSoWTAzgko06G/2" crossorigin="anonymous"></script>
    <script>
        let geocodedLat = null;
        let geocodedLng = null;

        const jobCategorySelect = document.getElementById('jobCategorySelect');
        const provinceSelect = document.getElementById('provinceSelect');
        const districtSelect = document.getElementById('districtSelect');
        const wardSelect = document.getElementById('wardSelect');
        const provinceNameInput = document.getElementById('provinceNameInput');
        const districtNameInput = document.getElementById('districtNameInput');
        const wardNameInput = document.getElementById('wardNameInput');
        const houseNumberInput = document.getElementById('houseNumberInput');
        const streetInput = document.getElementById('streetInput');
        const latitudeInput = document.getElementById('latitudeInput');
        const longitudeInput = document.getElementById('longitudeInput');
        const mapPinStatus = document.getElementById('mapPinStatus');
        const geocodeBtn = document.getElementById('geocodeBtn');
        const useCurrentLocationBtn = document.getElementById('useCurrentLocationBtn');
        const resetPinBtn = document.getElementById('resetPinBtn');

        let map = null;
        let marker = null;

        function updateCharCount(input, countId, max) {
            document.getElementById(countId).textContent = input.value.length + ' / ' + max;
        }



        async function readJsonSafe(response) {
            const raw = await response.text();
            if (!raw) return null;
            try { return JSON.parse(raw); } catch { return raw; }
        }

        function renderOptions(selectEl, items, valueField, textField) {
            if (!selectEl) return;
            const placeholder = selectEl.querySelector('option[value=""]');
            selectEl.innerHTML = '';
            if (placeholder) selectEl.appendChild(placeholder);

            items.forEach(item => {
                const opt = document.createElement('option');
                opt.value = item[valueField];
                opt.textContent = item[textField];
                selectEl.appendChild(opt);
            });
        }

        function setSelectAndHidden(selectEl, hiddenInput) {
            const selected = selectEl.options[selectEl.selectedIndex];
            hiddenInput.value = selected && selected.value ? selected.textContent.trim() : '';
        }

        function calculateDistanceMeters(lat1, lon1, lat2, lon2) {
            const R = 6371000;
            const dLat = (lat2 - lat1) * Math.PI / 180;
            const dLon = (lon2 - lon1) * Math.PI / 180;
            const a = Math.sin(dLat / 2) * Math.sin(dLat / 2) +
                      Math.cos(lat1 * Math.PI / 180) * Math.cos(lat2 * Math.PI / 180) *
                      Math.sin(dLon / 2) * Math.sin(dLon / 2);
            const c = 2 * Math.atan2(Math.sqrt(a), Math.sqrt(1 - a));
            return R * c;
        }

        function checkLocationTrust(lat, lng) {
            if (geocodedLat === null || geocodedLng === null) return '';
            const distance = calculateDistanceMeters(geocodedLat, geocodedLng, lat, lng);
            if (distance > 10000) {
                return ` <span style="color: #dc3545; font-weight: bold;">[Cảnh báo: Ghim lệch quá xa (${(distance / 1000).toFixed(1)} km). Bài đăng sẽ bị Admin kiểm duyệt!]</span>`;
            }
            if (distance > 2000) {
                return ` <span style="color: #ffc107; font-weight: bold;">[Cảnh báo: Ghim lệch khá xa (${(distance / 1000).toFixed(1)} km). Có thể bị Admin ẩn bài.]</span>`;
            }
            if (distance > 500) {
                return ` <span style="color: #0dcaf0; font-weight: bold;">[Lưu ý: Ghim hơi lệch (${Math.round(distance)}m).]</span>`;
            }
            return ` <span style="color: #198754; font-weight: bold;">[Khớp vị trí địa chỉ.]</span>`;
        }

        function setMapStatus(text) {
            if (!mapPinStatus) return;
            let trustText = '';
            if (latitudeInput.value && longitudeInput.value) {
                const lat = parseFloat(latitudeInput.value);
                const lng = parseFloat(longitudeInput.value);
                if (!isNaN(lat) && !isNaN(lng)) {
                    trustText = checkLocationTrust(lat, lng);
                }
            }
            mapPinStatus.innerHTML = text + trustText;
        }

        function setCoordinates(lat, lng) {
            latitudeInput.value = lat.toFixed(7);
            longitudeInput.value = lng.toFixed(7);
        }

        function clearCoordinates() {
            latitudeInput.value = '';
            longitudeInput.value = '';
        }

        function getExpectedAdministrative() {
            return {
                provinceName: (provinceNameInput.value || '').trim(),
                districtName: (districtNameInput.value || '').trim(),
                wardName: (wardNameInput.value || '').trim()
            };
        }

        function createOrMoveMarker(lat, lng) {
            if (!map || !window.L) return;

            if (!marker) {
                marker = window.L.marker([lat, lng], { draggable: true }).addTo(map);
                marker.on('dragend', async function () {
                    const p = marker.getLatLng();
                    setCoordinates(p.lat, p.lng);
                    await verifyPinnedLocation(p.lat, p.lng, 'kéo ghim thủ công');
                });
            } else {
                marker.setLatLng([lat, lng]);
            }

            map.setView([lat, lng], 16);
            setCoordinates(lat, lng);
        }

        async function ensureLeafletLoaded() {
            if (window.L) return;

            const cssId = 'leaflet-css-runtime';
            if (!document.getElementById(cssId)) {
                const link = document.createElement('link');
                link.id = cssId;
                link.rel = 'stylesheet';
                link.href = 'https://unpkg.com/leaflet@1.9.4/dist/leaflet.css';
                link.integrity = 'sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY=';
                link.crossOrigin = '';
                document.head.appendChild(link);
            }

            await new Promise((resolve, reject) => {
                const existing = document.getElementById('leaflet-js-runtime');
                if (existing) {
                    if (window.L) resolve();
                    else existing.addEventListener('load', resolve, { once: true });
                    return;
                }

                const script = document.createElement('script');
                script.id = 'leaflet-js-runtime';
                script.src = 'https://unpkg.com/leaflet@1.9.4/dist/leaflet.js';
                script.integrity = 'sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo=';
                script.crossOrigin = '';
                script.onload = resolve;
                script.onerror = reject;
                document.body.appendChild(script);
            });
        }

        async function initMap() {
            await ensureLeafletLoaded();

            const canvas = document.getElementById('jobPinMap');
            if (!canvas || map) return;

            const southwest = window.L.latLng(4.0, 99.0);
            const northeast = window.L.latLng(24.5, 120.0);
            const vietnamBounds = window.L.latLngBounds(southwest, northeast);

            map = window.L.map('jobPinMap', {
                center: [10.7769, 106.7009],
                zoom: 12,
                minZoom: 6,
                maxBounds: vietnamBounds,
                maxBoundsViscosity: 0.8,
                scrollWheelZoom: true
            });

            window.L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
                attribution: '&copy; OpenStreetMap contributors'
            }).addTo(map);

            map.on('click', function (e) {
                createOrMoveMarker(e.latlng.lat, e.latlng.lng);
                verifyPinnedLocation(e.latlng.lat, e.latlng.lng, 'bấm bản đồ thủ công');
            });
        }

        async function verifyPinnedLocation(lat, lng, sourceLabel) {
            const expected = getExpectedAdministrative();
            if (!expected.provinceName || !expected.districtName) {
                setMapStatus('Đã cập nhật ghim từ ' + sourceLabel + '. Hãy chọn tỉnh/quận để hệ thống kiểm tra khớp địa chỉ.');
                return;
            }

            try {
                const res = await fetch('/api/geocoding/reverse', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        latitude: lat,
                        longitude: lng,
                        provinceName: expected.provinceName,
                        districtName: expected.districtName,
                        wardName: expected.wardName
                    })
                });

                const data = await readJsonSafe(res);
                if (!res.ok || !data || !data.found) {
                    setMapStatus('Đã cập nhật ghim từ ' + sourceLabel + '. Chưa thể đối chiếu hành chính, bạn nên kiểm tra lại bằng mắt.');
                    return;
                }

                if (data.isAdministrativeMatch) {
                    setMapStatus('Ghim hợp lệ từ ' + sourceLabel + '. Khớp với tỉnh/quận/phường đã chọn.');
                    return;
                }

                const resolved = [data.resolvedWard, data.resolvedDistrict, data.resolvedProvince]
                    .filter(Boolean)
                    .join(', ');
                setMapStatus('Ghim từ ' + sourceLabel + ' nhưng lệch hành chính. Hệ thống thấy gần: ' + (resolved || 'không rõ') + '. Hãy kéo ghim lại.');
            } catch {
                setMapStatus('Đã cập nhật ghim từ ' + sourceLabel + '. Không thể đối chiếu tự động, bạn vui lòng kiểm tra lại bằng mắt.');
            }
        }

        async function loadProvinces() {
            const res = await fetch('/api/locations/provinces');
            const data = await readJsonSafe(res);
            if (!res.ok) throw new Error(typeof data === 'string' ? data : 'Không tải được tỉnh/thành.');

            renderOptions(provinceSelect, (data && data.items) || [], 'code', 'displayName');
        }

        async function loadDistricts(provinceCode) {
            districtSelect.disabled = true;
            wardSelect.disabled = true;
            districtSelect.innerHTML = '<option value="">— Chọn quận/huyện —</option>';
            wardSelect.innerHTML = '<option value="">— Chọn phường/xã —</option>';
            districtNameInput.value = '';
            wardNameInput.value = '';

            if (!provinceCode) return;

            const res = await fetch('/api/locations/districts?provinceCode=' + encodeURIComponent(provinceCode));
            const data = await readJsonSafe(res);
            if (!res.ok) throw new Error(typeof data === 'string' ? data : 'Không tải được quận/huyện.');

            renderOptions(districtSelect, (data && data.items) || [], 'code', 'displayName');
            districtSelect.disabled = false;
        }

        async function loadWards(districtCode) {
            wardSelect.disabled = true;
            wardSelect.innerHTML = '<option value="">— Chọn phường/xã —</option>';
            wardNameInput.value = '';

            if (!districtCode) return;

            const res = await fetch('/api/locations/wards?districtCode=' + encodeURIComponent(districtCode));
            const data = await readJsonSafe(res);
            if (!res.ok) throw new Error(typeof data === 'string' ? data : 'Không tải được phường/xã.');

            renderOptions(wardSelect, (data && data.items) || [], 'code', 'displayName');
            wardSelect.disabled = false;
        }

        async function geocodeCurrentAddress() {
            if (!provinceSelect.value || !districtSelect.value) {
                showToast('Vui lòng chọn tỉnh/thành và quận/huyện trước khi ghim.', 'error');
                return;
            }

            const payload = {
                provinceName: provinceNameInput.value,
                districtName: districtNameInput.value,
                wardName: wardNameInput.value,
                houseNumber: houseNumberInput.value.trim(),
                street: streetInput.value.trim()
            };

            geocodeBtn.disabled = true;
            geocodeBtn.textContent = 'Đang ghim...';

            try {
                const res = await fetch('/api/geocoding/forward', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(payload)
                });

                const data = await readJsonSafe(res);
                if (!res.ok) throw new Error(typeof data === 'string' ? data : 'Không thể geocode địa chỉ.');

                if (!data || !data.bestCandidate) {
                    throw new Error('Không tìm thấy vị trí phù hợp. Hãy nhập địa chỉ chi tiết hơn.');
                }

                await initMap();
                const best = data.bestCandidate;
                geocodedLat = best.latitude;
                geocodedLng = best.longitude;
                createOrMoveMarker(best.latitude, best.longitude);
                await verifyPinnedLocation(best.latitude, best.longitude, 'địa chỉ chi tiết');

                if (best.isAdministrativeMatch) {
                    showToast('Đã ghim vị trí thành công.', 'success');
                } else {
                    showToast('Vị trí ghim chưa thật sự chắc chắn, hãy kiểm tra kỹ.', 'error');
                }
            } catch (err) {
                showToast(err.message || 'Không thể ghim vị trí từ địa chỉ.', 'error');
                setMapStatus('Ghim thất bại. Hãy kiểm tra lại địa chỉ hoặc bấm trực tiếp lên bản đồ để ghim.');
            } finally {
                geocodeBtn.disabled = false;
                geocodeBtn.textContent = 'Ghim từ địa chỉ';
            }
        }

        function getCurrentPositionAsync() {
            return new Promise((resolve, reject) => {
                if (!navigator.geolocation) {
                    reject(new Error('Trình duyệt không hỗ trợ định vị.'));
                    return;
                }

                navigator.geolocation.getCurrentPosition(resolve, reject, {
                    enableHighAccuracy: true,
                    timeout: 10000,
                    maximumAge: 0
                });
            });
        }

        async function pinFromCurrentLocation() {
            if (!window.isSecureContext && location.hostname !== 'localhost') {
                showToast('Trình duyệt chỉ cho định vị trên HTTPS hoặc localhost.', 'error');
                return;
            }

            useCurrentLocationBtn.disabled = true;
            useCurrentLocationBtn.textContent = 'Đang lấy GPS...';

            try {
                await initMap();
                const pos = await getCurrentPositionAsync();
                const lat = pos.coords.latitude;
                const lng = pos.coords.longitude;

                createOrMoveMarker(lat, lng);
                map.setView([lat, lng], Math.max(map.getZoom(), 17));
                await verifyPinnedLocation(lat, lng, 'GPS thiết bị');
                if (typeof Swal !== 'undefined') {
                    Swal.fire({
                        title: 'Lưu ý vị trí GPS',
                        text: 'Vị trí hiện tại chỉ dùng để hỗ trợ đặt ghim. Nếu bạn đang không ở đúng công ty/nơi làm việc, hãy nhập địa chỉ và kéo ghim tới đúng vị trí thực tế của công việc.',
                        icon: 'info',
                        confirmButtonText: 'Đã hiểu'
                    });
                } else {
                    alert('Lưu ý vị trí GPS:\nVị trí hiện tại chỉ dùng để hỗ trợ đặt ghim. Nếu bạn đang không ở đúng công ty/nơi làm việc, hãy nhập địa chỉ và kéo ghim tới đúng vị trí thực tế của công việc.');
                }
                showToast('Đã lấy vị trí hiện tại. Hãy kiểm tra ghim rồi đăng bài.', 'success');
            } catch (err) {
                const msg = err && err.message ? err.message : 'Không thể lấy vị trí hiện tại.';
                showToast(msg, 'error');
                setMapStatus('Không lấy được vị trí thiết bị. Hãy thử lại hoặc dùng Ghim từ địa chỉ.');
            } finally {
                useCurrentLocationBtn.disabled = false;
                useCurrentLocationBtn.textContent = 'Lấy vị trí của tôi';
            }
        }

        async function loadJobLookupData() {
            try {
                const catRes = await fetch('/api/categories?type=job');

                const catJson = await readJsonSafe(catRes);

                if (!catRes.ok) throw new Error(typeof catJson === 'string' ? catJson : 'Không tải được danh mục việc làm.');

                renderOptions(jobCategorySelect, (catJson && catJson.items) || [], 'categoryId', 'categoryName');
                await loadProvinces();
                await initMap();
            } catch (err) {
                showToast(err.message || 'Không thể tải dữ liệu danh mục/khu vực.', 'error');
            }
        }

        document.getElementById('postJobForm').addEventListener('submit', async function(e) {
            e.preventDefault();
            var btn = document.getElementById('submitBtn');
            btn.disabled = true;
            btn.innerHTML = '<i class="fas fa-spinner fa-spin me-2"></i> Đang gửi...';

            var token = (window.UniMap360AuthStore && window.UniMap360AuthStore.getStoredToken)
                ? window.UniMap360AuthStore.getStoredToken()
                : (window.getToken ? window.getToken() : null);
            if (!token) {
                showToast('Bạn cần đăng nhập trước khi đăng tin.', 'error');
                btn.disabled = false;
                btn.innerHTML = '<i class="fas fa-paper-plane me-2"></i> Đăng Tin Ngay';
                return;
            }

            var form = e.target;

            if (!provinceSelect.value || !districtSelect.value) {
                showToast('Vui lòng chọn đầy đủ tỉnh/thành và quận/huyện.', 'error');
                btn.disabled = false;
                btn.innerHTML = '<i class="fas fa-paper-plane me-2"></i> Đăng Tin Ngay';
                return;
            }

            if (!latitudeInput.value || !longitudeInput.value) {
                showToast('Vui lòng ghim vị trí bản đồ trước khi đăng.', 'error');
                btn.disabled = false;
                btn.innerHTML = '<i class="fas fa-paper-plane me-2"></i> Đăng Tin Ngay';
                return;
            }

            const lat = parseFloat(latitudeInput.value);
            const lng = parseFloat(longitudeInput.value);
            if (geocodedLat !== null && geocodedLng !== null && !isNaN(lat) && !isNaN(lng)) {
                const distance = calculateDistanceMeters(geocodedLat, geocodedLng, lat, lng);
                if (distance > 2000) {
                    let confirmSubmit = false;
                    const distanceKmText = (distance / 1000).toFixed(1) + ' km';
                    if (typeof Swal !== 'undefined') {
                        const result = await Swal.fire({
                            title: 'Vị trí ghim lệch khá xa!',
                            text: `Vị trí ghim cách địa chỉ nhập khoảng ${distanceKmText}. Bạn có chắc chắn ghim này là chính xác? Tin đăng có thể bị Admin kiểm duyệt nếu thông tin không đúng thực tế.`,
                            icon: 'warning',
                            showCancelButton: true,
                            confirmButtonColor: '#3085d6',
                            cancelButtonColor: '#d33',
                            confirmButtonText: 'Đồng ý đăng',
                            cancelButtonText: 'Kiểm tra lại'
                        });
                        confirmSubmit = result.isConfirmed;
                    } else {
                        confirmSubmit = confirm(`Vị trí ghim cách địa chỉ nhập khoảng ${distanceKmText}. Bạn có chắc chắn ghim này là chính xác?\nTin đăng có thể bị Admin kiểm duyệt nếu thông tin không đúng thực tế.`);
                    }

                    if (!confirmSubmit) {
                        btn.disabled = false;
                        btn.innerHTML = '<i class="fas fa-paper-plane me-2"></i> Đăng Tin Ngay';
                        return;
                    }
                }
            }

            var body = {
                categoryId: parseInt(form.CategoryId.value) || 0,
                locationId: parseInt(form.LocationId.value) || 0,
                provinceCode: provinceSelect.value || null,
                provinceName: provinceNameInput.value || null,
                districtCode: districtSelect.value || null,
                districtName: districtNameInput.value || null,
                wardCode: wardSelect.value || null,
                wardName: wardNameInput.value || null,
                houseNumber: houseNumberInput.value.trim() || null,
                street: streetInput.value.trim() || null,
                latitude: parseFloat(latitudeInput.value),
                longitude: parseFloat(longitudeInput.value),
                geocodedLatitude: geocodedLat,
                geocodedLongitude: geocodedLng,
                jobTitle: form.JobTitle.value.trim(),
                salaryRange: form.SalaryRange.value.trim() || null,
                description: form.Description.value.trim() || null,
                contactPhone: form.ContactPhone.value.trim() || null,
                jobType: form.JobType.value.trim() || null,
                jobStatus: form.JobStatus.value.trim() || null
            };

            try {
                var res = await fetch('/api/employer/jobs', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify(body)
                });
                var data = await readJsonSafe(res);
                if (res.ok) {
                    showToast(data.message || 'Tạo việc làm thành công!', 'success');
                    form.reset();
                    document.getElementById('titleCount').textContent = '0 / 255';
                    districtSelect.disabled = true;
                    wardSelect.disabled = true;
                    provinceNameInput.value = '';
                    districtNameInput.value = '';
                    wardNameInput.value = '';
                    clearCoordinates();
                    geocodedLat = null;
                    geocodedLng = null;
                    if (marker && map) {
                        map.removeLayer(marker);
                        marker = null;
                    }
                    setMapStatus('Chưa có vị trí. Hãy chọn địa chỉ và bấm Ghim từ địa chỉ.');
                } else if (res.status === 403) {
                    showToast('Bạn không có quyền đăng việc làm.', 'error');
                } else {
                    showToast(typeof data === 'string' ? data : ((data && data.message) || JSON.stringify(data)), 'error');
                }
            } catch (err) {
                showToast('Lỗi kết nối máy chủ: ' + err.message, 'error');
            }

            btn.disabled = false;
            btn.innerHTML = '<i class="fas fa-paper-plane me-2"></i> Đăng Tin Ngay';
        });

        if (provinceSelect) {
            provinceSelect.addEventListener('change', async function () {
                setSelectAndHidden(provinceSelect, provinceNameInput);
                clearCoordinates();
                geocodedLat = null;
                geocodedLng = null;
                try {
                    await loadDistricts(provinceSelect.value);
                } catch (err) {
                    showToast(err.message || 'Không tải được quận/huyện.', 'error');
                }
            });
        }

        if (districtSelect) {
            districtSelect.addEventListener('change', async function () {
                setSelectAndHidden(districtSelect, districtNameInput);
                clearCoordinates();
                geocodedLat = null;
                geocodedLng = null;
                try {
                    await loadWards(districtSelect.value);
                } catch (err) {
                    showToast(err.message || 'Không tải được phường/xã.', 'error');
                }
            });
        }

        if (wardSelect) {
            wardSelect.addEventListener('change', function () {
                setSelectAndHidden(wardSelect, wardNameInput);
                clearCoordinates();
                geocodedLat = null;
                geocodedLng = null;
            });
        }

        if (geocodeBtn) {
            geocodeBtn.addEventListener('click', geocodeCurrentAddress);
        }

        if (useCurrentLocationBtn) {
            useCurrentLocationBtn.addEventListener('click', pinFromCurrentLocation);
        }

        if (resetPinBtn) {
            resetPinBtn.addEventListener('click', function () {
                clearCoordinates();
                geocodedLat = null;
                geocodedLng = null;
                if (marker && map) {
                    map.removeLayer(marker);
                    marker = null;
                }
                setMapStatus('Đã đặt lại ghim. Hãy bấm Ghim từ địa chỉ hoặc bấm trực tiếp lên bản đồ.');
            });
        }

        document.addEventListener('DOMContentLoaded', loadJobLookupData);
    </script>
}
