                <div class="auth-role-group mb-4" style="justify-content: center; gap: 10px;">
                    <label class="auth-role-option">
                        <input type="radio" name="GoogleRole" value="Student" checked>
                        <span><i class="fas fa-user-graduate"></i> Sinh viên</span>
                    </label>
                    <label class="auth-role-option">
                        <input type="radio" name="GoogleRole" value="Host">
                        <span><i class="fas fa-home"></i> Chủ trọ</span>
                    </label>
                    <label class="auth-role-option">
                        <input type="radio" name="GoogleRole" value="Employer">
                        <span><i class="fas fa-briefcase"></i> Tuyển dụng</span>
                    </label>
                </div>

                <button id="btnCompleteGoogleLogin" class="auth-btn w-100 mb-2">Hoàn tất <i class="fas fa-arrow-right ms-2"></i></button>
            </div>
        </div>
    </div>
</div>

<!-- Modal Quên Mật Khẩu -->
<div id="forgotPasswordModal" class="modal fade" tabindex="-1" aria-hidden="true" data-bs-backdrop="static">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content" style="border-radius: 15px; border: none; box-shadow: 0 10px 30px rgba(0,0,0,0.1);">
            <div class="modal-header border-0 pb-0">
                <h5 class="modal-title fw-bold" style="color: var(--color-primary);"><i class="fas fa-key me-2"></i>Quên mật khẩu</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body pt-2">
                <!-- Bước 1: Nhập Email -->
                <div id="fpStep1" class="px-3 pb-3">
                    <p class="text-muted mb-4 text-center">Nhập email của bạn để nhận mã xác thực (OTP).</p>
                    <div class="auth-input-group">
                        <i class="fas fa-envelope"></i>
                        <input type="email" id="fpEmail" class="auth-input" placeholder="Nhập địa chỉ Email" required />
                    </div>
                    <button id="btnFpSendOtp" class="auth-submit-btn w-100 mt-3" style="border-radius: 12px; font-size: 1rem; padding: 14px;">Nhận mã OTP</button>
                </div>
                
                <!-- Bước 2: Nhập OTP và Mật khẩu mới -->
                <div id="fpStep2" class="px-3 pb-3" style="display: none;">
                    <p class="text-muted mb-4 text-center" id="fpOtpMessage">Mã xác thực đã được gửi.</p>
                    <div class="auth-input-group mb-3">
                        <i class="fas fa-shield-alt"></i>
                        <input type="text" id="fpOtp" class="auth-input" placeholder="Nhập mã OTP (6 số)" maxlength="6" required style="letter-spacing: 2px; text-align: center; font-weight: bold; font-size: 1.2rem;" />
                    </div>
                    <div class="auth-input-group mb-4">
                        <i class="fas fa-lock"></i>
                        <input type="password" id="fpNewPassword" class="auth-input with-toggle" placeholder="Nhập mật khẩu mới" required />
                        <button type="button" class="auth-password-toggle" data-target="fpNewPassword" aria-label="Hiện mật khẩu" title="Hiện mật khẩu">
                            <i class="fas fa-eye"></i>
                        </button>
                    </div>
                    <button id="btnFpResetPassword" class="auth-submit-btn w-100 mb-3" style="border-radius: 12px; font-size: 1rem; padding: 14px;">Đặt lại mật khẩu</button>
                    <button id="btnFpBack" class="btn btn-light w-100 fw-bold" style="border-radius: 12px; color: #555; padding: 12px;"><i class="fas fa-arrow-left me-2"></i> Quay lại</button>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const STORAGE_KEY_TOKEN = 'unimap360.accessToken';
        const STORAGE_KEY_ACCOUNT = 'unimap360.account';
        const AUTH_COOKIE_TOKEN = 'unimap360.accessToken';

        function setTokenCookie(token, rememberMe) {
            if (!token) return;

            const attrs = ['path=/', 'SameSite=Lax'];
            if (window.location.protocol === 'https:') attrs.push('Secure');
            if (rememberMe) attrs.push('Max-Age=' + (60 * 60 * 24 * 7));

            document.cookie = AUTH_COOKIE_TOKEN + '=' + encodeURIComponent(token) + '; ' + attrs.join('; ');
        }

        function toggleAuth(type) {
            // Reset active classes
            document.getElementById('btn-show-login').classList.remove('active');
            document.getElementById('btn-show-register').classList.remove('active');
            document.getElementById('form-login').classList.remove('active');
            document.getElementById('form-register').classList.remove('active');

            // Apply new state
            if (type === 'login') {
                document.getElementById('btn-show-login').classList.add('active');
                document.getElementById('form-login').classList.add('active');
            } else {
                document.getElementById('btn-show-register').classList.add('active');
                document.getElementById('form-register').classList.add('active');
            }
        }

        function showFeedback(elementId, message, type) {
            const el = document.getElementById(elementId);
            if (!el) return;
            el.hidden = false;
            el.classList.remove('error', 'success');
            el.classList.add(type);
            el.textContent = message;
        }

        function clearFeedback(elementId) {
            const el = document.getElementById(elementId);
            if (!el) return;
            el.hidden = true;
            el.classList.remove('error', 'success');
            el.textContent = '';
        }

        function setSubmitting(form, isSubmitting) {
            const submitBtn = form.querySelector('button[type="submit"]');
            if (!submitBtn) return;
            submitBtn.disabled = isSubmitting;
            if (isSubmitting) {
                submitBtn.dataset.originalText = submitBtn.textContent;
                submitBtn.textContent = 'Đang xử lý...';
            } else if (submitBtn.dataset.originalText) {
                submitBtn.textContent = submitBtn.dataset.originalText;
            }
        }

        async function readResponsePayload(response) {
            const raw = await response.text();
            if (!raw) return null;
            try {
                const json = JSON.parse(raw);
                if (json && json.success === true && json.data !== undefined) {
                    return json.data;
                }
                return json;
            } catch {
                return raw;
            }
        }

        function extractErrorMessage(payload, fallbackMessage) {
            if (!payload) return fallbackMessage;
            if (typeof payload === 'string') return payload;
            if (payload.error && typeof payload.error.message === 'string') return payload.error.message;
            if (typeof payload.message === 'string' && payload.message.trim()) return payload.message;
            if (typeof payload.title === 'string' && payload.title.trim()) return payload.title;
            return fallbackMessage;
        }

        async function postJson(url, data) {
            const response = await fetch(url, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(data)
            });

            const payload = await readResponsePayload(response);
            if (!response.ok) {
                throw new Error(extractErrorMessage(payload, 'Có lỗi xảy ra, vui lòng thử lại.'));
            }
            return payload || {};
        }

        function saveAuthSession(authData, rememberMe) {
            const token = authData.accessToken;
            if (!token) return;

            setTokenCookie(token, rememberMe);

            const accountData = JSON.stringify({
                accountId: authData.accountId,
                email: authData.email,
                role: authData.role
            });

            if (rememberMe) {
                localStorage.setItem(STORAGE_KEY_TOKEN, token);
                localStorage.setItem(STORAGE_KEY_ACCOUNT, accountData);
                sessionStorage.removeItem(STORAGE_KEY_TOKEN);
                sessionStorage.removeItem(STORAGE_KEY_ACCOUNT);
                return;
            }

            sessionStorage.setItem(STORAGE_KEY_TOKEN, token);
            sessionStorage.setItem(STORAGE_KEY_ACCOUNT, accountData);
            localStorage.removeItem(STORAGE_KEY_TOKEN);
            localStorage.removeItem(STORAGE_KEY_ACCOUNT);
        }

        function notifyAuthChanged(authData) {
            const account = {
                accountId: authData.accountId,
                email: authData.email,
                role: authData.role
            };

            window.dispatchEvent(new CustomEvent('unimap360:auth-changed', {
                detail: { account }
            }));
        }

        function wirePasswordToggles() {
            const toggleButtons = document.querySelectorAll('.auth-password-toggle');
            toggleButtons.forEach((button) => {
                button.addEventListener('click', () => {
                    const targetId = button.getAttribute('data-target');
                    const input = targetId ? document.getElementById(targetId) : null;
                    const icon = button.querySelector('i');
                    if (!input || !icon) return;

                    const isHidden = input.type === 'password';
                    input.type = isHidden ? 'text' : 'password';
                    icon.classList.toggle('fa-eye', !isHidden);
                    icon.classList.toggle('fa-eye-slash', isHidden);
                    const label = isHidden ? 'Ẩn mật khẩu' : 'Hiện mật khẩu';
                    button.setAttribute('aria-label', label);
                    button.setAttribute('title', label);
                });
            });
        }

        function redirectByRole(role) {
            const normalized = (role || '').toLowerCase();
            if (normalized === 'admin') {
                window.location.href = '/Admin';
                return;
            }
            if (normalized === 'host' || normalized === 'employer') {
                window.location.href = '/Home/Listing';
                return;
            }
            window.location.href = '/';
        }

        async function handleLoginSubmit(event) {
            event.preventDefault();
            clearFeedback('loginFeedback');

            const form = event.currentTarget;
            const formData = new FormData(form);
            const email = (formData.get('Email') || '').toString().trim();
            const password = (formData.get('Password') || '').toString();
            const rememberMe = !!form.querySelector('input[type="checkbox"]:checked');

            if (!email || !password) {
                showFeedback('loginFeedback', 'Vui lòng nhập đầy đủ email và mật khẩu.', 'error');
                return;
            }

            setSubmitting(form, true);
            try {
                const authData = await postJson('/api/auth/login', { email, password });
                saveAuthSession(authData, rememberMe);
                notifyAuthChanged(authData);
                showFeedback('loginFeedback', 'Đăng nhập thành công. Đang chuyển trang...', 'success');
                setTimeout(() => redirectByRole(authData.role), 400);
            } catch (error) {
                showFeedback('loginFeedback', error.message || 'Đăng nhập thất bại.', 'error');
            } finally {
                setSubmitting(form, false);
            }
        }

        async function handleRegisterSubmit(event) {
            event.preventDefault();
            clearFeedback('registerFeedback');

            const form = event.currentTarget;
            const formData = new FormData(form);
            const role = (formData.get('Role') || 'Student').toString();
            const email = (formData.get('Email') || '').toString().trim();
            const otp = (formData.get('Otp') || '').toString().trim();
            const password = (formData.get('Password') || '').toString();
            const confirmPassword = (formData.get('ConfirmPassword') || '').toString();

            if (!email || !password || !otp) {
                showFeedback('registerFeedback', 'Vui lòng nhập đầy đủ Email, Mã OTP và Mật khẩu.', 'error');
                return;
            }

            if (!email.toLowerCase().endsWith('@@gmail.com')) {
                showFeedback('registerFeedback', 'Xin lỗi, hiện tại chúng tôi chỉ hỗ trợ đăng ký bằng tài khoản @@gmail.com.', 'error');
                return;
            }

            if (password.length < 8) {
                showFeedback('registerFeedback', 'Mật khẩu cần có ít nhất 8 ký tự.', 'error');
                return;
            }

            if (password !== confirmPassword) {
                showFeedback('registerFeedback', 'Mật khẩu xác nhận không khớp.', 'error');
                return;
            }

            setSubmitting(form, true);
            try {
                await postJson('/api/auth/register', { email, password, role, otp });
                showFeedback('registerFeedback', 'Đăng ký thành công. Bạn có thể đăng nhập ngay bây giờ.', 'success');

                const loginEmailInput = document.querySelector('#loginForm input[name="Email"]');
                if (loginEmailInput) loginEmailInput.value = email;

                setTimeout(() => toggleAuth('login'), 600);
            } catch (error) {
                showFeedback('registerFeedback', error.message || 'Đăng ký thất bại.', 'error');
            } finally {
                setSubmitting(form, false);
            }
        }

        document.addEventListener('DOMContentLoaded', () => {
            const loginForm = document.getElementById('loginForm');
            const registerForm = document.getElementById('registerForm');
            const btnSendRegisterOtp = document.getElementById('btn-send-register-otp');

            if (btnSendRegisterOtp) {
                btnSendRegisterOtp.addEventListener('click', async () => {
                    const emailInput = document.getElementById('register-email');
                    const email = emailInput ? emailInput.value.trim() : '';

                    if (!email) {
                        showFeedback('registerFeedback', 'Vui lòng nhập Email trước khi lấy mã OTP.', 'error');
                        return;
                    }

                    if (!email.toLowerCase().endsWith('@@gmail.com')) {
                        showFeedback('registerFeedback', 'Xin lỗi, hệ thống chỉ hỗ trợ tài khoản @@gmail.com.', 'error');
                        return;
                    }

                    btnSendRegisterOtp.disabled = true;
                    btnSendRegisterOtp.textContent = 'Đang gửi...';
                    clearFeedback('registerFeedback');

                    try {
                        await postJson('/api/auth/send-register-otp', { email });
                        showFeedback('registerFeedback', 'Mã OTP đã được gửi đến email của bạn. Mã có hiệu lực trong 2 phút.', 'success');

                        // Đếm ngược 120s
                        let timeLeft = 120;
                        btnSendRegisterOtp.textContent = `Chờ ${timeLeft}s`;
                        
                        const timer = setInterval(() => {
                            timeLeft--;
                            if (timeLeft <= 0) {
                                clearInterval(timer);
                                btnSendRegisterOtp.textContent = 'Gửi lại mã';
                                btnSendRegisterOtp.disabled = false;
                            } else {
                                btnSendRegisterOtp.textContent = `Chờ ${timeLeft}s`;
                            }
                        }, 1000);

                    } catch (error) {
                        btnSendRegisterOtp.disabled = false;
                        btnSendRegisterOtp.textContent = 'Gửi mã';
                        showFeedback('registerFeedback', error.message || 'Không thể gửi mã OTP. Vui lòng thử lại.', 'error');
                    }
                });
            }

            if (loginForm) loginForm.addEventListener('submit', handleLoginSubmit);
            if (registerForm) registerForm.addEventListener('submit', handleRegisterSubmit);
            wirePasswordToggles();

            // Bind auth toggle buttons (removed inline onclick)
            document.querySelectorAll('.auth-toggle-btn').forEach(function(btn) {
                btn.addEventListener('click', function() {
                    const target = this.getAttribute('data-auth-target');
                    if (target) toggleAuth(target);
                });
            });
        });
    </script>
    
    <!-- Google Identity Services -->
    <script src="https://accounts.google.com/gsi/client" async defer></script>
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            // Khởi tạo Google Sign-In từ cấu hình bảo mật
            var googleClientId = '@Configuration["OAuth:GoogleClientId"]';
            
            window.onload = function () {
                if(googleClientId && googleClientId.length > 0) {
                    google.accounts.id.initialize({
                        client_id: googleClientId,
                        callback: handleGoogleCredentialResponse,
                        auto_select: false,
                        cancel_on_tap_outside: true
                    });
                } else {
                    console.error("Google Client ID chưa được cấu hình trong secrets.ini");
                }
            };

            async function handleGoogleCredentialResponse(response) {
                if (!response.credential) return;
                
                showToast('Đang kết nối tới máy chủ...', 'info');
                
                try {
                    const res = await fetch('/api/auth/google', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ credential: response.credential })
                    });
                    
                    if (res.ok) {
                        const payload = await res.json();
                        const isSuccess = payload.success || payload.Success;
                        const data = payload.data || payload.Data;

                        if (isSuccess && data) {
                            if (data.requireRole) {
                                window.pendingGoogleCredential = response.credential;
                                const roleModal = new bootstrap.Modal(document.getElementById('googleRoleModal'));
                                roleModal.show();
                            } else if (data.accessToken) {
                                saveAuthSession(data, true);
                                notifyAuthChanged(data);
                                showToast('Đăng nhập Google thành công! Đang chuyển hướng...', 'success');
                                setTimeout(() => redirectByRole(data.role), 1000);
                            }
                        } else {
                            const msg = (payload.error?.message || payload.Error?.Message) || 'Dữ liệu xác thực không hợp lệ';
                            showToast(msg, 'error');
                        }
                    } else {
                        showToast('Xác thực thất bại. Vui lòng thử lại.', 'error');
                    }
                } catch (error) {
                    console.error(error);
                    showToast('Lỗi kết nối. Vui lòng thử lại.', 'error');
                }
            }

            document.getElementById('btn-google-login').addEventListener('click', function (e) {
                e.preventDefault();
                if(!googleClientId) {
                    showToast('Tính năng đăng nhập Google chưa được cấu hình!', 'error');
                    return;
                }
                google.accounts.id.prompt((notification) => {
                    if (notification.isNotDisplayed() || notification.isSkippedMoment()) {
                        showToast('Vui lòng cho phép popup đăng nhập Google', 'warning');
                    }
                });
            });

            // Xử lý nút hoàn tất đăng ký với Google Role
            const btnCompleteGoogleLogin = document.getElementById('btnCompleteGoogleLogin');
            if (btnCompleteGoogleLogin) {
                btnCompleteGoogleLogin.addEventListener('click', async function() {
                    if (!window.pendingGoogleCredential) return;
                    
                    const selectedRoleObj = document.querySelector('input[name="GoogleRole"]:checked');
                    if (!selectedRoleObj) {
                        showToast('Vui lòng chọn một vai trò.', 'warning');
                        return;
                    }
                    
                    const selectedRole = selectedRoleObj.value;
                    const btn = this;
                    btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Đang xử lý...';
                    btn.disabled = true;

                    try {
                        const res = await postJson('/api/auth/google', { credential: window.pendingGoogleCredential, role: selectedRole });
                        if (res && res.accessToken) {
                            saveAuthSession(res, true);
                            notifyAuthChanged(res);
                            const roleModalElement = document.getElementById('googleRoleModal');
                            const roleModal = bootstrap.Modal.getInstance(roleModalElement) || new bootstrap.Modal(roleModalElement);
                            roleModal.hide();
                            
                            showToast('Tạo tài khoản Google thành công! Đang chuyển hướng...', 'success');
                            setTimeout(() => redirectByRole(res.role), 1000);
                        } else {
                            showToast('Có lỗi xảy ra, vui lòng thử lại.', 'error');
                            btn.innerHTML = 'Hoàn tất <i class="fas fa-arrow-right ms-2"></i>';
                            btn.disabled = false;
                        }
                    } catch (err) {
                        showToast(err.message || 'Lỗi kết nối. Vui lòng thử lại.', 'error');
                        btn.innerHTML = 'Hoàn tất <i class="fas fa-arrow-right ms-2"></i>';
                        btn.disabled = false;
                    }
                });
            }

            // XỬ LÝ QUÊN MẬT KHẨU
            const forgotPasswordLinks = document.querySelectorAll('.auth-forgot-password');
            const fpModalElement = document.getElementById('forgotPasswordModal');
            let fpModal;
            if (fpModalElement) {
                fpModal = new bootstrap.Modal(fpModalElement);
            }

            forgotPasswordLinks.forEach(link => {
                link.addEventListener('click', function(e) {
                    e.preventDefault();
                    if (fpModal) {
                        document.getElementById('fpStep1').style.display = 'block';
                        document.getElementById('fpStep2').style.display = 'none';
                        document.getElementById('fpEmail').value = document.querySelector('input[name="Email"]').value || '';
                        fpModal.show();
                    }
                });
            });

            const btnFpSendOtp = document.getElementById('btnFpSendOtp');
            if (btnFpSendOtp) {
                btnFpSendOtp.addEventListener('click', async function() {
                    const email = document.getElementById('fpEmail').value.trim();
                    if (!email) { showToast('Vui lòng nhập Email', 'warning'); return; }
                    
                    btnFpSendOtp.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Đang gửi...';
                    btnFpSendOtp.disabled = true;

                    try {
                        const res = await postJson('/api/auth/forgot-password', { email });
                        // Trong môi trường DEV, Backend trả về trực tiếp OTP trong payload.otp
                        if (res && res.message) {
                            document.getElementById('fpStep1').style.display = 'none';
                            document.getElementById('fpStep2').style.display = 'block';
                            
                            // Hiển thị thông báo (Thực tế không hiện mã OTP nữa)
                            if (window.Swal) {
                                Swal.fire({
                                    title: 'Đã gửi mã xác thực',
                                    text: 'Vui lòng kiểm tra hòm thư Email của bạn để lấy mã OTP.',
                                    icon: 'success',
                                    confirmButtonText: 'Đóng',
                                    confirmButtonColor: '#780115'
                                });
                            } else {
                                showToast('Mã OTP đã được gửi đến Email của bạn.', 'success');
                            }
                            document.getElementById('fpOtpMessage').innerHTML = `Vui lòng nhập mã xác thực gồm 6 chữ số đã được gửi tới hòm thư của bạn.`;
                        }
                    } catch (err) {
                        showToast(err.message || 'Lỗi gửi yêu cầu', 'error');
                    } finally {
                        btnFpSendOtp.innerHTML = 'Nhận mã OTP';
                        btnFpSendOtp.disabled = false;
                    }
                });
            }

            const btnFpBack = document.getElementById('btnFpBack');
            if (btnFpBack) {
                btnFpBack.addEventListener('click', () => {
                    document.getElementById('fpStep1').style.display = 'block';
                    document.getElementById('fpStep2').style.display = 'none';
                });
            }

            const btnFpResetPassword = document.getElementById('btnFpResetPassword');
            if (btnFpResetPassword) {
                btnFpResetPassword.addEventListener('click', async function() {
                    const email = document.getElementById('fpEmail').value.trim();
                    const otp = document.getElementById('fpOtp').value.trim();
                    const newPassword = document.getElementById('fpNewPassword').value;

                    if (!otp || !newPassword) { showToast('Vui lòng nhập đủ mã OTP và Mật khẩu mới', 'warning'); return; }
                    if (newPassword.length < 6) { showToast('Mật khẩu mới phải có ít nhất 6 ký tự', 'warning'); return; }

                    btnFpResetPassword.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Đang xử lý...';
                    btnFpResetPassword.disabled = true;

                    try {
                        const res = await postJson('/api/auth/reset-password', { email, otp, newPassword });
                        if (res && res.message) {
                            showToast('Đổi mật khẩu thành công! Vui lòng đăng nhập lại.', 'success');
                            fpModal.hide();
                            // Chuyển form về trạng thái đăng nhập
                            toggleAuth('login');
                        }
                    } catch (err) {
                        showToast(err.message || 'Lỗi kết nối', 'error');
                    } finally {
                        btnFpResetPassword.innerHTML = 'Đặt lại mật khẩu';
                        btnFpResetPassword.disabled = false;
                    }
                });
            }
        });
    </script>
}
