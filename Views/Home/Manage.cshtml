@section Scripts {
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
    let currentRole = '';
    let isVipUser = false;
    let isBillingEnforced = false;
    let itemsData = [];
    let deleteTargetId = null;
    let deleteTargetType = '';
    let deleteModalInstance = null;
    let postAnalyticsModalInstance = null;
    let overviewChart = null;
    let postDetailChart = null;
    let roomCategories = [];
    let jobCategories = [];
    let provinceOptions = [];
    const districtCache = new Map();
    const wardCache = new Map();

    function getAccount() {
        if (window.UniMap360AuthStore && typeof window.UniMap360AuthStore.getStoredAccount === 'function') {
            return window.UniMap360AuthStore.getStoredAccount();
        }
        return null;
    }
    


    function setupStatusFilterByRole() {
        const select = document.getElementById('statusFilter');
        if (!select) return;

        const options = currentRole === 'host'
            ? [
                { value: 'Available', text: 'Còn trống' },
                { value: 'Rented', text: 'Đã cho thuê' },
                { value: 'Hidden', text: 'Đã ẩn' },
                { value: 'Rejected', text: 'Đã từ chối' }
            ]
            : [
                { value: 'Open', text: 'Đang tuyển' },
                { value: 'Closed', text: 'Đã đóng' },
                { value: 'Hidden', text: 'Đã ẩn' },
                { value: 'Rejected', text: 'Đã từ chối' }
            ];

        select.innerHTML = '<option value="">Tất cả trạng thái</option>';
        options.forEach(option => {
            const node = document.createElement('option');
            node.value = option.value;
            node.textContent = option.text;
            select.appendChild(node);
        });
    }

    async function readJsonSafe(response) {
        const raw = await response.text();
        if (!raw) return null;
        try { return JSON.parse(raw); } catch { return raw; }
    }

    function getErrorMessage(data, defaultMsg) {
        if (!data) return defaultMsg;
        if (typeof data === 'string') return data;
        const errObj = data.error || data.Error;
        if (errObj && typeof errObj === 'object') {
            return errObj.message || errObj.Message || defaultMsg;
        }
        return data.message || data.Message || defaultMsg;
    }

    function escapeHtml(value) {
        return String(value ?? '')
            .replaceAll('&', '&amp;')
            .replaceAll('<', '&lt;')
            .replaceAll('>', '&gt;')
            .replaceAll('"', '&quot;')
            .replaceAll("'", '&#39;');
    }

    function renderOptions(selectEl, items, valueField, textField) {
        if (!selectEl) return;

        const placeholder = selectEl.querySelector('option[value=""]');
        selectEl.innerHTML = '';
        if (placeholder) selectEl.appendChild(placeholder);

        items.forEach(item => {
            const opt = document.createElement('option');
            opt.value = item[valueField];
            opt.textContent = item[textField];
            selectEl.appendChild(opt);
        });
    }

    async function loadDistrictOptions(provinceCode) {
        if (!provinceCode) return [];
        if (districtCache.has(provinceCode)) return districtCache.get(provinceCode);

        const res = await fetch('/api/locations/districts?provinceCode=' + encodeURIComponent(provinceCode));
        const data = await readJsonSafe(res);
        const items = res.ok && data && data.items ? data.items : [];
        districtCache.set(provinceCode, items);
        return items;
    }

    async function loadWardOptions(districtCode) {
        if (!districtCode) return [];
        if (wardCache.has(districtCode)) return wardCache.get(districtCode);

        const res = await fetch('/api/locations/wards?districtCode=' + encodeURIComponent(districtCode));
        const data = await readJsonSafe(res);
        const items = res.ok && data && data.items ? data.items : [];
        wardCache.set(districtCode, items);
        return items;
    }

    function setLocationStatus(form, text) {
        const statusEl = form.querySelector('.js-map-status');
        if (statusEl) statusEl.textContent = text;
    }

    function setCoordinates(form, lat, lng) {
        const latInput = form.querySelector('input[name="Latitude"]');
        const lngInput = form.querySelector('input[name="Longitude"]');
        latInput.value = Number(lat).toFixed(7);
        lngInput.value = Number(lng).toFixed(7);
    }

    function clearCoordinates(form) {
        const latInput = form.querySelector('input[name="Latitude"]');
        const lngInput = form.querySelector('input[name="Longitude"]');
        latInput.value = '';
        lngInput.value = '';
    }

    async function initializeLocationEditor(form, item) {
        if (!item) return;
        const provinceSelect = form.querySelector('select[name="ProvinceCode"]');
        const districtSelect = form.querySelector('select[name="DistrictCode"]');
        const wardSelect = form.querySelector('select[name="WardCode"]');
        const geocodeBtn = form.querySelector('.js-geocode-btn');
        const gpsBtn = form.querySelector('.js-gps-btn');
        const resetBtn = form.querySelector('.js-reset-pin-btn');
        const mapCanvas = form.querySelector('.js-map-canvas');

        renderOptions(provinceSelect, provinceOptions, 'code', 'displayName');

        const mapState = {
            map: null,
            marker: null
        };
        form._mapState = mapState;

        if (window.L && mapCanvas) {
            const southwest = window.L.latLng(4.0, 99.0);
            const northeast = window.L.latLng(24.5, 120.0);
            const vietnamBounds = window.L.latLngBounds(southwest, northeast);

            mapState.map = window.L.map(mapCanvas, {
                center: [10.7769, 106.7009],
                zoom: 12,
                minZoom: 6,
                maxBounds: vietnamBounds,
                maxBoundsViscosity: 0.8,
                scrollWheelZoom: true
            });

            window.L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
                attribution: '&copy; OpenStreetMap contributors'
            }).addTo(mapState.map);

            mapState.map.on('click', e => {
                createOrMoveMarker(form, e.latlng.lat, e.latlng.lng);
                setLocationStatus(form, 'Đã cập nhật vị trí từ thao tác bấm bản đồ.');
            });
        }

        const location = item.location || {};
        form.OriginalLocationId.value = item.locationId || 0;
        form.querySelector('input[name="HouseNumber"]').value = location.houseNumber || '';
        form.querySelector('input[name="Street"]').value = location.street || '';

        const provinceCode = location.provinceCode ? String(location.provinceCode) : '';
        const districtCode = location.districtCode ? String(location.districtCode) : '';
        const wardCode = location.wardCode ? String(location.wardCode) : '';

        if (provinceCode) {
            provinceSelect.value = provinceCode;
            const districts = await loadDistrictOptions(provinceCode);
            renderOptions(districtSelect, districts, 'code', 'displayName');
            districtSelect.disabled = false;
            if (districtCode) {
                districtSelect.value = districtCode;
                const wards = await loadWardOptions(districtCode);
                renderOptions(wardSelect, wards, 'code', 'displayName');
                wardSelect.disabled = false;
                if (wardCode) wardSelect.value = wardCode;
            }
        }

        if (location.latitude != null && location.longitude != null) {
            createOrMoveMarker(form, Number(location.latitude), Number(location.longitude));
            setLocationStatus(form, 'Đã tải vị trí hiện tại của bài đăng.');
        } else {
            setLocationStatus(form, 'Chưa có vị trí. Hãy chọn địa chỉ và ghim vị trí.');
        }

        form.dataset.originalLocation = JSON.stringify({
            locationId: item.locationId || 0,
            provinceCode: provinceCode,
            districtCode: districtCode,
            wardCode: wardCode,
            houseNumber: (location.houseNumber || '').trim(),
            street: (location.street || '').trim(),
            latitude: location.latitude != null ? Number(location.latitude).toFixed(7) : '',
            longitude: location.longitude != null ? Number(location.longitude).toFixed(7) : ''
        });

        provinceSelect.addEventListener('change', async () => {
            clearCoordinates(form);
            districtSelect.innerHTML = '<option value="">— Chọn quận/huyện —</option>';
            wardSelect.innerHTML = '<option value="">— Chọn phường/xã —</option>';
            districtSelect.disabled = true;
            wardSelect.disabled = true;
            if (!provinceSelect.value) return;

            const districts = await loadDistrictOptions(provinceSelect.value);
            renderOptions(districtSelect, districts, 'code', 'displayName');
            districtSelect.disabled = false;
        });

        districtSelect.addEventListener('change', async () => {
            clearCoordinates(form);
            wardSelect.innerHTML = '<option value="">— Chọn phường/xã —</option>';
            wardSelect.disabled = true;
            if (!districtSelect.value) return;

            const wards = await loadWardOptions(districtSelect.value);
            renderOptions(wardSelect, wards, 'code', 'displayName');
            wardSelect.disabled = false;
        });

        wardSelect.addEventListener('change', () => {
            clearCoordinates(form);
        });

        geocodeBtn.addEventListener('click', async () => {
            const provinceName = provinceSelect.options[provinceSelect.selectedIndex]?.textContent?.trim() || '';
            const districtName = districtSelect.options[districtSelect.selectedIndex]?.textContent?.trim() || '';
            const wardName = wardSelect.options[wardSelect.selectedIndex]?.textContent?.trim() || '';
            const houseNumber = form.querySelector('input[name="HouseNumber"]').value.trim();
            const street = form.querySelector('input[name="Street"]').value.trim();

            if (!provinceSelect.value || !districtSelect.value) {
                showToast('Vui lòng chọn tỉnh/thành và quận/huyện trước khi ghim.', 'error');
                return;
            }

            geocodeBtn.disabled = true;
            geocodeBtn.textContent = 'Đang ghim...';
            try {
                const res = await fetch('/api/geocoding/forward', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ provinceName, districtName, wardName, houseNumber, street })
                });
                const data = await readJsonSafe(res);
                if (!res.ok || !data || !data.bestCandidate) {
                    showToast('Không tìm thấy vị trí phù hợp.', 'error');
                    return;
                }

                createOrMoveMarker(form, data.bestCandidate.latitude, data.bestCandidate.longitude);
                setLocationStatus(form, 'Đã ghim vị trí từ địa chỉ.');
            } finally {
                geocodeBtn.disabled = false;
                geocodeBtn.textContent = 'Ghim từ địa chỉ';
            }
        });

        gpsBtn.addEventListener('click', async () => {
            if (!navigator.geolocation) {
                showToast('Trình duyệt không hỗ trợ định vị.', 'error');
                return;
            }

            gpsBtn.disabled = true;
            gpsBtn.textContent = 'Đang lấy GPS...';
            try {
                const position = await new Promise((resolve, reject) => {
                    navigator.geolocation.getCurrentPosition(resolve, reject, {
                        enableHighAccuracy: true,
                        timeout: 10000,
                        maximumAge: 0
                    });
                });
                createOrMoveMarker(form, position.coords.latitude, position.coords.longitude);
                setLocationStatus(form, 'Đã ghim vị trí từ GPS thiết bị.');
            } catch {
                showToast('Không thể lấy vị trí hiện tại.', 'error');
            } finally {
                gpsBtn.disabled = false;
                gpsBtn.textContent = 'Lấy vị trí của tôi';
            }
        });

        resetBtn.addEventListener('click', () => {
            clearCoordinates(form);
            if (form._mapState?.map && form._mapState?.marker) {
                form._mapState.map.removeLayer(form._mapState.marker);
                form._mapState.marker = null;
            }
            setLocationStatus(form, 'Đã đặt lại ghim vị trí.');
        });
    }

    function createOrMoveMarker(form, lat, lng) {
        const mapState = form._mapState;
        if (!mapState || !mapState.map) return;

        if (!mapState.marker) {
            mapState.marker = window.L.marker([lat, lng], { draggable: true }).addTo(mapState.map);
            mapState.marker.on('dragend', () => {
                const p = mapState.marker.getLatLng();
                setCoordinates(form, p.lat, p.lng);
                setLocationStatus(form, 'Đã cập nhật vị trí từ thao tác kéo ghim.');
            });
        } else {
            mapState.marker.setLatLng([lat, lng]);
        }

        mapState.map.setView([lat, lng], 16);
        setCoordinates(form, lat, lng);
    }

    function hasLocationChanged(form) {
        const original = JSON.parse(form.dataset.originalLocation || '{}');
        const current = {
            provinceCode: (form.ProvinceCode.value || '').trim(),
            districtCode: (form.DistrictCode.value || '').trim(),
            wardCode: (form.WardCode.value || '').trim(),
            houseNumber: (form.HouseNumber.value || '').trim(),
            street: (form.Street.value || '').trim(),
            latitude: (form.Latitude.value || '').trim(),
            longitude: (form.Longitude.value || '').trim()
        };

        return current.provinceCode !== (original.provinceCode || '')
            || current.districtCode !== (original.districtCode || '')
            || current.wardCode !== (original.wardCode || '')
            || current.houseNumber !== (original.houseNumber || '')
            || current.street !== (original.street || '')
            || current.latitude !== (original.latitude || '')
            || current.longitude !== (original.longitude || '');
    }

    async function loadLookupData() {
        try {
            const [metaRes, provinceRes] = await Promise.all([
                fetch('/api/manage-posts/metadata', {
                    credentials: 'same-origin'
                }),
                fetch('/api/locations/provinces')
            ]);

            const json = await readJsonSafe(metaRes);
            const provinceJson = await readJsonSafe(provinceRes);
            if (!metaRes.ok || !json) {
                roomCategories = [];
                jobCategories = [];
                provinceOptions = [];
                return;
            }

            const categories = Array.isArray(json.categories) ? json.categories : [];

            if ((json.role || '').toLowerCase() === 'host') {
                roomCategories = categories;
                jobCategories = [];
            } else {
                jobCategories = categories;
                roomCategories = [];
            }

            provinceOptions = provinceRes.ok && provinceJson && provinceJson.items
                ? provinceJson.items
                : [];
        } catch {
            roomCategories = [];
            jobCategories = [];
            provinceOptions = [];
        }
    }

    document.addEventListener('DOMContentLoaded', async () => {
        const acc = getAccount();
        if (!acc || !acc.email) {
            window.location.href = '/Home/Auth';
            return;
        }
        currentRole = (acc.role || '').toLowerCase();
        
        const btnNew = document.getElementById('btn-post-new');
        if (currentRole === 'host') {
            btnNew.href = '/Home/PostRoom';
            btnNew.style.display = 'inline-block';
        } else if (currentRole === 'employer') {
            btnNew.href = '/Home/PostJob';
            btnNew.style.display = 'inline-block';
        }
        setupStatusFilterByRole();

        // Fetch detailed profile to verify VIP status and display badge
        try {
            const profileRes = await fetch('/api/profile', { credentials: 'same-origin' });
            if (profileRes.ok) {
                const profileData = await profileRes.json();
                if (profileData) {
                    isVipUser = profileData.isVip === true;
                    isBillingEnforced = profileData.billingEnforced === true;
                    
                    if (isVipUser) {
                        const badgeEl = document.getElementById('manageVipBadge');
                        if (badgeEl) {
                            badgeEl.innerHTML = `<span class="badge" style="background: #780115; color: #FFD700; border: 1px solid #FFD700; font-size: 0.75rem; font-weight: 800; padding: 4px 10px; letter-spacing: 0.5px; border-radius: 20px; display: inline-flex; align-items: center; gap: 4px; box-shadow: 0 2px 5px rgba(120, 1, 21, 0.2);"><i class="fas fa-crown"></i> PRO</span>`;
                        }
                    }

                    const tabAnalytics = document.getElementById('tab-analytics');
                    if (tabAnalytics) {
                        if (isBillingEnforced && !isVipUser) {
                            tabAnalytics.style.position = 'relative';
                            tabAnalytics.style.opacity = '0.7';
                            tabAnalytics.style.cursor = 'not-allowed';
                            tabAnalytics.style.filter = 'grayscale(30%)';
                            if (!tabAnalytics.querySelector('.js-pro-tab-badge')) {
                                const proBadge = document.createElement('span');
                                proBadge.className = 'badge js-pro-tab-badge';
                                proBadge.style.cssText = 'background: #780115; color: #FFD700; border: 1px solid #FFD700; font-size: 0.55rem; font-weight: 800; padding: 2px 4px; border-radius: 4px; position: absolute; top: -6px; right: -5px; z-index: 10; scale: 0.8; letter-spacing: 0.5px;';
                                proBadge.innerText = 'PRO';
                                tabAnalytics.appendChild(proBadge);
                            }
                        } else {
                            tabAnalytics.style.position = '';
                            tabAnalytics.style.opacity = '';
                            tabAnalytics.style.cursor = '';
                            tabAnalytics.style.filter = '';
                            const existingBadge = tabAnalytics.querySelector('.js-pro-tab-badge');
                            if (existingBadge) {
                                existingBadge.remove();
                            }
                        }
                    }
                }
            }
        } catch (err) {
            console.error("Error checking VIP status on dashboard:", err);
        }

        await loadLookupData();
        await fetchListings();
        deleteModalInstance = new bootstrap.Modal(document.getElementById('deleteModal'));
        postAnalyticsModalInstance = new bootstrap.Modal(document.getElementById('postAnalyticsModal'));

        // Tab Switcher logic
        const tabListings = document.getElementById('tab-listings');
        const tabAnalytics = document.getElementById('tab-analytics');
        const listingsContainer = document.getElementById('listingsViewContainer');
        const analyticsContainer = document.getElementById('manageAnalytics');

        if (tabListings && tabAnalytics && listingsContainer && analyticsContainer) {
            tabListings.addEventListener('click', () => {
                tabListings.classList.add('active');
                tabAnalytics.classList.remove('active');
                listingsContainer.style.display = 'block';
                analyticsContainer.style.display = 'none';
            });

            tabAnalytics.addEventListener('click', async () => {
                if (isBillingEnforced && !isVipUser) {
                    handleVipRedirect();
                    return;
                }
                tabAnalytics.classList.add('active');
                tabListings.classList.remove('active');
                listingsContainer.style.display = 'none';
                analyticsContainer.style.display = 'block';
                await loadOverviewAnalytics();
            });
        }

        // Stats Button delegated listener
        document.body.addEventListener('click', function(e) {
            const btn = e.target.closest('.js-stats-btn');
            if (!btn) return;
            const targetId = parseInt(btn.getAttribute('data-id'));
            const targetType = btn.getAttribute('data-type');
            const targetTitle = btn.getAttribute('data-title');
            openDetailAnalytics(targetId, targetType, targetTitle);
        });
        
        document.getElementById('confirmDeleteBtn').addEventListener('click', doDelete);
        document.getElementById('searchInput').addEventListener('input', renderList);
        document.getElementById('statusFilter').addEventListener('change', renderList);

        // Bind dynamic action buttons (removed inline onclick)
        document.body.addEventListener('click', function(e) {
            const btn = e.target.closest('.js-action-btn');
            if (!btn) return;
            const action = btn.getAttribute('data-action');
            if (action === 'askDelete') askDelete(btn);
            else if (action === 'closeEdit') closeEdit(btn);
            else if (action === 'toggleEdit') toggleEdit(btn.getAttribute('data-id'));
        });

        let isVipToggling = false;
        // Bind VIP toggles
        document.body.addEventListener('change', async function(e) {
            const toggle = e.target.closest('.js-vip-toggle');
            if (!toggle) return;

            if (isVipToggling) {
                toggle.checked = !toggle.checked; // Revert immediately
                return;
            }

            const id = parseInt(toggle.getAttribute('data-id'));
            const targetType = toggle.getAttribute('data-type');
            const featureType = toggle.getAttribute('data-feature');
            const isChecked = toggle.checked;

            isVipToggling = true;

            const endpoint = isChecked ? '/api/business/pin' : '/api/business/unpin';
            try {
                const res = await fetch(endpoint, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ targetType, targetId: id, featureType })
                });

                if (res.status === 403) {
                    showToast("Tính năng này yêu cầu gói cước VIP. Đang chuyển hướng...", "warning");
                    setTimeout(() => {
                        window.location.href = '/Home/Pricing?returnUrl=' + encodeURIComponent(window.location.pathname);
                    }, 2000);
                    toggle.checked = !isChecked; // Revert state
                    return;
                }

                const data = await readJsonSafe(res);
                if (res.ok) {
                    showToast(isChecked ? 'Ghim tin đăng thành công!' : 'Đã hủy ghim tin đăng!', 'success');
                    await fetchListings();
                } else {
                    showToast(getErrorMessage(data, 'Lỗi xử lý ghim VIP'), 'error');
                    toggle.checked = !isChecked; // Revert state
                }
            } catch (err) {
                showToast('Lỗi kết nối mạng', 'error');
                toggle.checked = !isChecked; // Revert state
            } finally {
                isVipToggling = false;
            }
        });
    });

    async function fetchListings() {
        if (currentRole !== 'host' && currentRole !== 'employer') {
            document.getElementById('manageResults').innerHTML = '<div class="empty-state">Tài khoản của bạn không có quyền đăng bài.</div>';
            return;
        }

        try {
            const res = await fetch('/api/manage-posts/items', {
                credentials: 'same-origin'
            });
            if (res.ok) {
                const data = await readJsonSafe(res);
                itemsData = data.items || [];
                renderList();
            } else {
                showToast('Lỗi tải dữ liệu', 'error');
            }
        } catch (e) {
            showToast('Lỗi mạng', 'error');
        }
    }

    window.handleVipRedirect = function(e) {
        if (e) {
            e.preventDefault();
            e.stopPropagation();
        }
        showToast("Tính năng này yêu cầu gói cước VIP. Đang chuyển hướng...", "warning");
        setTimeout(() => {
            window.location.href = '/Home/Pricing?returnUrl=' + encodeURIComponent(window.location.pathname);
        }, 2000);
    };

    function renderList() {
        const container = document.getElementById('manageResults');
        const q = document.getElementById('searchInput').value.toLowerCase();
        const stat = document.getElementById('statusFilter').value;

        let filtered = itemsData.filter(x => {
            const title = (x.title || x.jobTitle || '').toLowerCase();
            const st = x.roomStatus || x.jobStatus || '';
            if (q && !title.includes(q)) return false;
            if (stat && st !== stat) return false;
            return true;
        });

        if (filtered.length === 0) {
            container.innerHTML = `
                <div class="empty-state">
                    <i class="fas fa-box-open"></i>
                    <h4>Chưa có bài đăng nào</h4>
                    <p class="text-muted">Bạn chưa có bài đăng nào hoặc không có kết quả tìm kiếm.</p>
                </div>`;
            return;
        }

        let html = '';
        filtered.forEach(x => {
            const id = x.roomId || x.jobId;
            const title = x.title || x.jobTitle || 'Không có tiêu đề';
            const status = x.roomStatus || x.jobStatus || 'Open';
            const dt = new Date(x.createdAt).toLocaleDateString();
            const isRoom = currentRole === 'host';
            let extra = '';
            
            if (isRoom) {
                extra = `<span><i class="fas fa-tag"></i> ${new Intl.NumberFormat('vi-VN').format(x.price)} đ</span>
                         <span><i class="fas fa-vector-square"></i> ${escapeHtml(x.area)} m²</span>`;
            } else {
                extra = `<span><i class="fas fa-money-bill"></i> Lương: ${escapeHtml(x.salaryRange || 'Thỏa thuận')}</span>
                         <span><i class="fas fa-clock"></i> ${escapeHtml(x.jobType || 'Part-time')}</span>`;
            }

            let badgeClass = (status === 'Available' || status === 'Open') ? 'badge-open' : 'badge-closed';
            const showVipOverlay = isBillingEnforced && !isVipUser;
            
            html += `
                <div class="item-card" id="card-${id}" data-id="${id}" data-type="${isRoom ? 'room' : 'job'}">
                    <div class="item-summary">
                        <div class="item-summary-left">
                            <h4>${escapeHtml(title)}</h4>
                            <div class="item-meta">
                                <span class="meta-badge ${badgeClass}">${escapeHtml(status)}</span>
                                <span><i class="fas fa-calendar-alt"></i> ${dt}</span>
                            </div>
                            <div class="item-meta mt-1">${extra}</div>
                        </div>
                        <div class="item-summary-right d-flex align-items-center">
                            <!-- VIP Pinning Switches -->
                            <div class="vip-toggle-container-wrapper" ${showVipOverlay ? `onclick="handleVipRedirect(event)"` : ''} style="position: relative; display: inline-flex; cursor: ${showVipOverlay ? 'not-allowed' : 'default'};">
                                <div class="vip-toggle-container me-3" style="${showVipOverlay ? 'pointer-events: none;' : ''}">
                                    <input type="checkbox" id="map-${id}" class="js-vip-toggle" data-id="${id}" data-type="${isRoom ? 'Room' : 'Job'}" data-feature="MapPinned" ${x.isMapPinned ? 'checked' : ''} style="display:none;" ${showVipOverlay ? 'disabled' : ''}>
                                    <label for="map-${id}" class="vip-toggle-btn vip-map-btn" style="position: relative; ${showVipOverlay ? 'opacity: 0.55; filter: blur(0.3px) grayscale(30%); cursor: not-allowed;' : ''}">
                                        Ghim Bản đồ
                                        ${showVipOverlay ? '<span class="badge" style="background: #780115; color: #FFD700; border: 1px solid #FFD700; font-size: 0.55rem; font-weight: 800; padding: 2px 4px; border-radius: 4px; position: absolute; top: -8px; right: -5px; z-index: 10; scale: 0.8; letter-spacing: 0.5px;">PRO</span>' : ''}
                                    </label>

                                    <input type="checkbox" id="explore-${id}" class="js-vip-toggle" data-id="${id}" data-type="${isRoom ? 'Room' : 'Job'}" data-feature="ExplorePriority" ${x.isExplorePriority ? 'checked' : ''} style="display:none;" ${showVipOverlay ? 'disabled' : ''}>
                                    <label for="explore-${id}" class="vip-toggle-btn vip-explore-btn" style="position: relative; ${showVipOverlay ? 'opacity: 0.55; filter: blur(0.3px) grayscale(30%); cursor: not-allowed;' : ''}">
                                        Ghim Khám phá
                                        ${showVipOverlay ? '<span class="badge" style="background: #780115; color: #FFD700; border: 1px solid #FFD700; font-size: 0.55rem; font-weight: 800; padding: 2px 4px; border-radius: 4px; position: absolute; top: -8px; right: -5px; z-index: 10; scale: 0.8; letter-spacing: 0.5px;">PRO</span>' : ''}
                                    </label>
                                </div>
                            </div>
                            ${showVipOverlay ? `
                            <button class="btn-action btn-stats me-2" onclick="handleVipRedirect(event)" style="position: relative; opacity: 0.65; filter: blur(0.3px) grayscale(30%); cursor: not-allowed;">
                                <i class="fas fa-chart-bar"></i> Thống kê
                                <span class="badge" style="background: #780115; color: #FFD700; border: 1px solid #FFD700; font-size: 0.55rem; font-weight: 800; padding: 2px 4px; border-radius: 4px; position: absolute; top: -8px; right: -5px; z-index: 10; scale: 0.8; letter-spacing: 0.5px;">PRO</span>
                            </button>
                            ` : `
                            <button class="btn-action btn-stats js-stats-btn me-2" data-id="${id}" data-type="${isRoom ? 'Room' : 'Job'}" data-title="${escapeHtml(title)}">
                                <i class="fas fa-chart-bar"></i> Thống kê
                            </button>
                            `}
                            <button class="btn-action btn-edit js-action-btn" data-action="toggleEdit" data-id="${id}">
                                <i class="fas fa-pen"></i> Chỉnh sửa
                            </button>
                        </div>
                    </div>
                    <div class="item-detail" id="detail-${id}"></div>
                </div>
            `;
        });
        container.innerHTML = html;
    }

    function toggleEdit(id) {
        const card = document.getElementById('card-' + id);
        const detailDiv = document.getElementById('detail-' + id);
        const isEditing = card.classList.contains('is-editing');
        const btn = card.querySelector('.btn-edit');

        // Đóng các item khác
        document.querySelectorAll('.item-card').forEach(c => {
            if (c.id !== 'card-' + id) {
                c.classList.remove('is-editing');
                const b = c.querySelector('.btn-edit');
                if (b) {
                    b.innerHTML = '<i class="fas fa-pen"></i> Chỉnh sửa';
                    b.classList.remove('btn-editing');
                }
                c.querySelector('.item-detail').innerHTML = '';
            }
        });

        if (isEditing) {
            // Đóng item hiện tại
            card.classList.remove('is-editing');
            detailDiv.innerHTML = '';
            btn.innerHTML = '<i class="fas fa-pen"></i> Chỉnh sửa';
            btn.classList.remove('btn-editing');
        } else {
            // Mở item
            const type = card.dataset.type;
            const tpl = document.getElementById(type === 'room' ? 'tpl-edit-room' : 'tpl-edit-job').innerHTML;
            detailDiv.innerHTML = tpl;
            card.classList.add('is-editing');
            btn.innerHTML = '<i class="fas fa-chevron-up"></i> Đóng lại';
            btn.classList.add('btn-editing');
            
            // Xử lý Form
            const form = detailDiv.querySelector('form');
            form.dataset.id = id;
            populateFormOptions(form, type);
            fillForm(form, id, type);
            initializeLocationEditor(form, itemsData.find(x => x.roomId == id || x.jobId == id));
            form.addEventListener('submit', handleSave);
        }
    }

    function populateFormOptions(form, type) {
        const categoryItems = type === 'room' ? roomCategories : jobCategories;
        renderOptions(form.CategoryId, categoryItems, 'categoryId', 'categoryName');
    }

    function closeEdit(btn) {
        const card = btn.closest('.item-card');
        const id = card.dataset.id;
        toggleEdit(id);
    }

    function fillForm(form, id, type) {
        const item = itemsData.find(x => x.roomId == id || x.jobId == id);
        if (!item) return;

        form.CategoryId.value = item.categoryId;
        form.OriginalLocationId.value = item.locationId || 0;
        form.ContactPhone.value = item.contactPhone || '';
        form.Description.value = item.description || '';

        if (type === 'room') {
            form.Title.value = item.title;
            form.Price.value = item.price;
            form.Area.value = item.area;
            form.RoomStatus.value = item.roomStatus;
        } else {
            form.JobTitle.value = item.jobTitle;
            form.SalaryRange.value = item.salaryRange || '';
            form.JobType.value = item.jobType || '';
            form.JobStatus.value = item.jobStatus;
        }
    }

    async function handleSave(e) {
        e.preventDefault();
        const form = e.target;
        const id = form.dataset.id;
        const type = form.dataset.type;
        const btnSave = form.querySelector('.btn-save');
        
        btnSave.disabled = true;
        btnSave.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Đang lưu';

        const body = {
            categoryId: parseInt(form.CategoryId.value) || 0,
            locationId: parseInt(form.OriginalLocationId.value) || 0,
            contactPhone: form.ContactPhone.value.trim() || null,
            description: form.Description.value.trim() || null
        };

        const locationChanged = hasLocationChanged(form);
        if (locationChanged) {
            if (!form.ProvinceCode.value || !form.DistrictCode.value || !form.Latitude.value || !form.Longitude.value) {
                showToast('Khi đổi địa chỉ, bạn cần chọn tỉnh/quận và ghim vị trí bản đồ.', 'error');
                btnSave.disabled = false;
                btnSave.innerHTML = 'Lưu chỉnh sửa';
                return;
            }

            body.locationId = 0;
            body.provinceCode = form.ProvinceCode.value || null;
            body.provinceName = form.ProvinceCode.options[form.ProvinceCode.selectedIndex]?.textContent?.trim() || null;
            body.districtCode = form.DistrictCode.value || null;
            body.districtName = form.DistrictCode.options[form.DistrictCode.selectedIndex]?.textContent?.trim() || null;
            body.wardCode = form.WardCode.value || null;
            body.wardName = form.WardCode.options[form.WardCode.selectedIndex]?.textContent?.trim() || null;
            body.houseNumber = form.HouseNumber.value.trim() || null;
            body.street = form.Street.value.trim() || null;
            body.latitude = parseFloat(form.Latitude.value);
            body.longitude = parseFloat(form.Longitude.value);
        }

        if (type === 'room') {
            body.title = form.Title.value.trim();
            body.price = parseFloat(form.Price.value) || 0;
            body.area = parseFloat(form.Area.value) || 0;
            body.roomStatus = form.RoomStatus.value.trim() || null;
        } else {
            body.jobTitle = form.JobTitle.value.trim();
            body.salaryRange = form.SalaryRange.value.trim() || null;
            body.jobType = form.JobType.value.trim() || null;
            body.jobStatus = form.JobStatus.value.trim() || null;
        }

        const endpoint = type === 'room' ? `/api/host/rooms/${id}` : `/api/employer/jobs/${id}`;
        
        try {
            const res = await fetch(endpoint, {
                method: 'PUT',
                headers: {
                    'Content-Type': 'application/json'
                },
                body: JSON.stringify(body)
            });
            const data = await readJsonSafe(res);
            if (res.ok) {
                showToast('Lưu thành công!', 'success');
                await fetchListings();
            } else {
                showToast(getErrorMessage(data, 'Lỗi lưu dữ liệu'), 'error');
            }
        } catch (err) {
            showToast('Lỗi mạng', 'error');
        }

        if(btnSave) {
            btnSave.disabled = false;
            btnSave.innerHTML = 'Lưu chỉnh sửa';
        }
    }

    function askDelete(btn) {
        const form = btn.closest('form');
        deleteTargetId = form.dataset.id;
        deleteTargetType = form.dataset.type;
        deleteModalInstance.show();
    }

    async function doDelete() {
        if (!deleteTargetId) return;
        const btn = document.getElementById('confirmDeleteBtn');
        btn.disabled = true;
        btn.innerHTML = 'Đang xóa...';

        const endpoint = deleteTargetType === 'room' 
            ? `/api/host/rooms/${deleteTargetId}` 
            : `/api/employer/jobs/${deleteTargetId}`;

        try {
            const res = await fetch(endpoint, {
                method: 'DELETE',
                credentials: 'same-origin'
            });
            if (res.ok) {
                showToast('Đã xóa thành công', 'success');
                deleteModalInstance.hide();
                await fetchListings();
            } else {
                const data = await readJsonSafe(res);
                showToast(getErrorMessage(data, 'Lỗi xóa'), 'error');
            }
        } catch (err) {
            showToast('Lỗi mạng', 'error');
        }
        
        btn.disabled = false;
        btn.innerHTML = 'Xóa bài đăng';
    }

    async function loadOverviewAnalytics() {
        try {
            const startDate = new Date();
            startDate.setDate(startDate.getDate() - 30);
            const startDateStr = startDate.toISOString().split('T')[0];
            
            const res = await fetch(`/api/business/analytics/overview?startDate=${startDateStr}`, {
                credentials: 'same-origin'
            });

            if (res.status === 403) {
                showToast("Tính năng này yêu cầu gói cước VIP. Đang chuyển hướng...", "warning");
                setTimeout(() => {
                    window.location.href = '/Home/Pricing?returnUrl=' + encodeURIComponent(window.location.pathname);
                }, 2000);
                return;
            }

            if (!res.ok) {
                showToast('Không thể tải dữ liệu thống kê tổng quan.', 'error');
                return;
            }
            
            const data = await readJsonSafe(res);
            if (!data) return;

            // Render stats cards
            document.getElementById('stat-total-views').textContent = data.totalViews || 0;
            document.getElementById('stat-total-chats').textContent = data.totalChats || 0;
            document.getElementById('stat-total-favorites').textContent = data.totalFavorites || 0;
            
            // Role dependent labels
            const isRoom = currentRole === 'host';
            const appLabel = document.getElementById('stat-appointment-label');
            const appIcon = document.getElementById('stat-appointment-icon');
            const appValue = document.getElementById('stat-total-appointments');
            
            if (isRoom) {
                appLabel.textContent = 'Đặt lịch hẹn';
                appIcon.innerHTML = '<i class="fas fa-calendar-check"></i>';
                appValue.textContent = data.totalAppointments || 0;
            } else {
                appLabel.textContent = 'Nộp ứng tuyển';
                appIcon.innerHTML = '<i class="fas fa-file-signature"></i>';
                appValue.textContent = data.totalApplications || 0;
            }

            // Populate Top Performing Posts
            const topContainer = document.getElementById('topPerformingContainer');
            topContainer.innerHTML = '';
            const topPosts = data.topPerformingPosts || [];
            
            if (topPosts.length === 0) {
                topContainer.innerHTML = '<div class="text-center py-4 text-muted">Chưa có dữ liệu bài đăng nổi bật.</div>';
            } else {
                // Find max views to compute percentage for progress bars
                const maxViews = Math.max(...topPosts.map(p => p.views), 1);
                
                topPosts.forEach(post => {
                    const pct = Math.round((post.views / maxViews) * 100);
                    const postItem = document.createElement('div');
                    postItem.className = 'top-post-item';
                    postItem.innerHTML = `
                        <div class="top-post-meta">
                            <div class="top-post-title" title="${escapeHtml(post.title)}">${escapeHtml(post.title)}</div>
                            <div class="top-post-bar-bg">
                                <div class="top-post-bar-fill" style="width: ${pct}%"></div>
                            </div>
                        </div>
                        <div class="top-post-stats">
                            <span><i class="fas fa-eye"></i> ${post.views}</span>
                            <span><i class="fas fa-comments"></i> ${post.chats}</span>
                        </div>
                    `;
                    topContainer.appendChild(postItem);
                });
            }

            // Render Overview Trend Chart
            const ctx = document.getElementById('overviewTrendsChart').getContext('2d');
            if (overviewChart) {
                overviewChart.destroy();
            }
            
            const dailyMetrics = data.dailyMetrics || [];
            const labels = dailyMetrics.map(m => {
                const d = new Date(m.date);
                return `${d.getDate()}/${d.getMonth() + 1}`;
            });
            
            const viewsData = dailyMetrics.map(m => m.views);
            const chatsData = dailyMetrics.map(m => m.chats);
            const appointmentsData = dailyMetrics.map(m => isRoom ? m.appointments : m.applications);

            // Premium chart gradients
            const gradientViews = ctx.createLinearGradient(0, 0, 0, 300);
            gradientViews.addColorStop(0, 'rgba(255, 187, 0, 0.25)');
            gradientViews.addColorStop(1, 'rgba(255, 187, 0, 0.0)');
            
            const gradientChats = ctx.createLinearGradient(0, 0, 0, 300);
            gradientChats.addColorStop(0, 'rgba(40, 167, 69, 0.25)');
            gradientChats.addColorStop(1, 'rgba(40, 167, 69, 0.0)');

            const gradientApps = ctx.createLinearGradient(0, 0, 0, 300);
            gradientApps.addColorStop(0, 'rgba(0, 123, 255, 0.25)');
            gradientApps.addColorStop(1, 'rgba(0, 123, 255, 0.0)');

            overviewChart = new Chart(ctx, {
                type: 'line',
                data: {
                    labels: labels,
                    datasets: [
                        {
                            label: 'Lượt xem',
                            data: viewsData,
                            borderColor: '#ffc107',
                            backgroundColor: gradientViews,
                            fill: true,
                            tension: 0.4,
                            borderWidth: 3,
                            pointBackgroundColor: '#ffc107',
                            pointHoverRadius: 7
                        },
                        {
                            label: 'Lượt Chat',
                            data: chatsData,
                            borderColor: '#28a745',
                            backgroundColor: gradientChats,
                            fill: true,
                            tension: 0.4,
                            borderWidth: 3,
                            pointBackgroundColor: '#28a745',
                            pointHoverRadius: 7
                        },
                        {
                            label: isRoom ? 'Đặt lịch hẹn' : 'Ứng tuyển',
                            data: appointmentsData,
                            borderColor: '#007bff',
                            backgroundColor: gradientApps,
                            fill: true,
                            tension: 0.4,
                            borderWidth: 3,
                            pointBackgroundColor: '#007bff',
                            pointHoverRadius: 7
                        }
                    ]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: {
                            position: 'top',
                            labels: {
                                boxWidth: 12,
                                font: {
                                    weight: 'bold',
                                    size: 11
                                }
                            }
                        }
                    },
                    scales: {
                        y: {
                            beginAtZero: true,
                            grid: {
                                color: '#f1f5f9'
                            },
                            ticks: {
                                stepSize: 1
                            }
                        },
                        x: {
                            grid: {
                                display: false
                            }
                        }
                    }
                }
            });

        } catch (err) {
            console.error(err);
            showToast('Lỗi tải biểu đồ tổng quan.', 'error');
        }
    }

    async function openDetailAnalytics(targetId, targetType, targetTitle) {
        if (!targetId || !targetType) return;
        
        const isRoom = targetType === 'Room';
        const titleEl = document.getElementById('postAnalyticsTitle');
        titleEl.textContent = `Thống kê chi tiết: ${targetTitle || (isRoom ? 'Phòng trọ' : 'Việc làm')}`;

        const grid = document.getElementById('postAnalyticsGrid');
        grid.innerHTML = '<div class="text-center py-4 w-100"><i class="fas fa-spinner fa-spin fa-2x text-muted"></i></div>';

        postAnalyticsModalInstance.show();

        try {
            // Get past 30 days of data
            const startDate = new Date();
            startDate.setDate(startDate.getDate() - 30);
            const startDateStr = startDate.toISOString().split('T')[0];

            const res = await fetch(`/api/business/analytics/post/${targetType}/${targetId}?startDate=${startDateStr}`, {
                credentials: 'same-origin'
            });

            if (res.status === 403) {
                showToast("Tính năng này yêu cầu gói cước VIP. Đang chuyển hướng...", "warning");
                setTimeout(() => {
                    window.location.href = '/Home/Pricing?returnUrl=' + encodeURIComponent(window.location.pathname);
                }, 2000);
                postAnalyticsModalInstance.hide();
                return;
            }

            if (!res.ok) {
                showToast('Không thể tải dữ liệu thống kê của bài đăng.', 'error');
                grid.innerHTML = '<div class="text-center py-4 w-100 text-danger">Lỗi tải dữ liệu.</div>';
                return;
            }

            const data = await readJsonSafe(res);
            if (!data) return;

            // Render stats grid
            grid.innerHTML = `
                <div class="stat-card-glass stat-views">
                    <div class="stat-card-icon"><i class="fas fa-eye"></i></div>
                    <div class="stat-card-info">
                        <h3>${data.totalViews || 0}</h3>
                        <p>Lượt xem</p>
                    </div>
                </div>
                <div class="stat-card-glass stat-chats">
                    <div class="stat-card-icon"><i class="fas fa-comments"></i></div>
                    <div class="stat-card-info">
                        <h3>${data.totalChats || 0}</h3>
                        <p>Lượt Chat</p>
                    </div>
                </div>
                <div class="stat-card-glass stat-favorites">
                    <div class="stat-card-icon"><i class="fas fa-heart"></i></div>
                    <div class="stat-card-info">
                        <h3>${data.totalFavorites || 0}</h3>
                        <p>Yêu thích</p>
                    </div>
                </div>
                <div class="stat-card-glass stat-appointments">
                    <div class="stat-card-icon">${isRoom ? '<i class="fas fa-calendar-check"></i>' : '<i class="fas fa-file-signature"></i>'}</div>
                    <div class="stat-card-info">
                        <h3>${isRoom ? (data.totalAppointments || 0) : (data.totalApplications || 0)}</h3>
                        <p>${isRoom ? 'Đặt lịch hẹn' : 'Ứng tuyển'}</p>
                    </div>
                </div>
            `;

            // Draw line chart
            const ctx = document.getElementById('postDetailTrendsChart').getContext('2d');
            if (postDetailChart) {
                postDetailChart.destroy();
            }

            const dailyMetrics = data.dailyMetrics || [];
            const labels = dailyMetrics.map(m => {
                const d = new Date(m.date);
                return `${d.getDate()}/${d.getMonth() + 1}`;
            });

            const viewsData = dailyMetrics.map(m => m.views);
            const chatsData = dailyMetrics.map(m => m.chats);
            const appointmentsData = dailyMetrics.map(m => isRoom ? m.appointments : m.applications);

            // Premium chart gradients
            const gradientViews = ctx.createLinearGradient(0, 0, 0, 250);
            gradientViews.addColorStop(0, 'rgba(255, 187, 0, 0.25)');
            gradientViews.addColorStop(1, 'rgba(255, 187, 0, 0.0)');
            
            const gradientChats = ctx.createLinearGradient(0, 0, 0, 250);
            gradientChats.addColorStop(0, 'rgba(40, 167, 69, 0.25)');
            gradientChats.addColorStop(1, 'rgba(40, 167, 69, 0.0)');

            const gradientApps = ctx.createLinearGradient(0, 0, 0, 250);
            gradientApps.addColorStop(0, 'rgba(0, 123, 255, 0.25)');
            gradientApps.addColorStop(1, 'rgba(0, 123, 255, 0.0)');

            postDetailChart = new Chart(ctx, {
                type: 'line',
                data: {
                    labels: labels,
                    datasets: [
                        {
                            label: 'Lượt xem',
                            data: viewsData,
                            borderColor: '#ffc107',
                            backgroundColor: gradientViews,
                            fill: true,
                            tension: 0.4,
                            borderWidth: 3,
                            pointBackgroundColor: '#ffc107',
                            pointHoverRadius: 6
                        },
                        {
                            label: 'Lượt Chat',
                            data: chatsData,
                            borderColor: '#28a745',
                            backgroundColor: gradientChats,
                            fill: true,
                            tension: 0.4,
                            borderWidth: 3,
                            pointBackgroundColor: '#28a745',
                            pointHoverRadius: 6
                        },
                        {
                            label: isRoom ? 'Đặt lịch hẹn' : 'Ứng tuyển',
                            data: appointmentsData,
                            borderColor: '#007bff',
                            backgroundColor: gradientApps,
                            fill: true,
                            tension: 0.4,
                            borderWidth: 3,
                            pointBackgroundColor: '#007bff',
                            pointHoverRadius: 6
                        }
                    ]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: {
                            position: 'top',
                            labels: {
                                boxWidth: 10,
                                font: {
                                    weight: 'bold',
                                    size: 10
                                }
                            }
                        }
                    },
                    scales: {
                        y: {
                            beginAtZero: true,
                            grid: {
                                color: '#f1f5f9'
                            },
                            ticks: {
                                stepSize: 1
                            }
                        },
                        x: {
                            grid: {
                                display: false
                            }
                        }
                    }
                }
            });

        } catch (err) {
            console.error(err);
            showToast('Lỗi kết nối tải thống kê.', 'error');
            grid.innerHTML = '<div class="text-center py-4 w-100 text-danger">Lỗi kết nối mạng.</div>';
        }
    }
</script>
}
