@{
    ViewData["Title"] = "Quản lý bài đăng";
}

<style>
    .manage-page-wrapper {
        min-height: calc(100vh - var(--app-nav-height, 70px));
        background-color: var(--color-bg);
        padding: 40px 0;
    }
    .manage-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-end;
        margin-bottom: 30px;
    }
    .manage-header h2 {
        font-weight: 800;
        margin-bottom: 5px;
    }
    .manage-header p {
        color: var(--color-text-muted);
        margin: 0;
    }
    .manage-toolbar {
        background: #fff;
        padding: 15px 20px;
        border-radius: 12px;
        border: 1px solid var(--color-border);
        box-shadow: var(--shadow-card);
        margin-bottom: 25px;
        display: flex;
        gap: 15px;
        transition: box-shadow var(--motion-base) var(--ease-cinematic), border-color var(--motion-base) var(--ease-cinematic);
    }
    .manage-toolbar:focus-within {
        border-color: var(--color-border-dark);
        box-shadow: var(--shadow-float);
    }
    .manage-toolbar input, .manage-toolbar select {
        padding: 10px 15px;
        border: 2px solid var(--color-border);
        border-radius: 8px;
        outline: none;
    }
    .manage-toolbar input { flex: 1; }

    .item-card {
        background: #fff;
        border-radius: 12px;
        box-shadow: var(--shadow-card);
        margin-bottom: 15px;
        overflow: hidden;
        border: 1px solid var(--color-border);
        transition: border-color var(--motion-base) var(--ease-cinematic), box-shadow var(--motion-base) var(--ease-cinematic), transform var(--motion-fast) var(--ease-cinematic);
    }
    .item-card:hover {
        transform: translateY(-2px);
        box-shadow: var(--shadow-float);
    }
    .item-card.is-editing {
        border-color: var(--color-primary);
    }
    .item-summary {
        padding: 20px 25px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        background: #fff;
    }
    .item-summary-left h4 {
        font-weight: 700;
        font-size: 1.1rem;
        margin-bottom: 8px;
    }
    .item-meta {
        font-size: 0.85rem;
        color: var(--color-text-muted);
        display: flex;
        gap: 15px;
        margin-bottom: 4px;
    }
    .meta-badge {
        padding: 3px 8px;
        border-radius: 4px;
        font-weight: 600;
        font-size: 0.75rem;
    }
    .badge-open { background: #e8f5e9; color: #2e7d32; }
    .badge-closed { background: #ffebee; color: #c62828; }
    
    .item-summary-right { display: flex; gap: 10px; }
    .btn-action {
        padding: 8px 16px;
        border-radius: 8px;
        font-weight: 600;
        font-size: 0.9rem;
        cursor: pointer;
        border: none;
        transition: all 0.2s;
    }
    .btn-edit { background: #f0f0f0; color: #333; }
    .btn-edit:hover { background: #e0e0e0; }
    .btn-editing { background: var(--color-primary); color: #fff; }
    
    .item-detail {
        display: none;
        padding: 25px;
        background: #fafafa;
        border-top: 1px solid #eee;
    }
    .item-card.is-editing .item-detail { display: block; }
    
    /* Edit Form Styles (Reused from Post) */
    .form-label-custom { font-weight: 700; font-size: 0.9rem; margin-bottom: 5px; display: block; }
    .form-input { width: 100%; padding: 10px 15px; border: 2px solid var(--color-border); border-radius: 8px; margin-bottom: 15px; background: #fff;}
    .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 15px; }
    .action-bar { display: flex; justify-content: flex-end; gap: 10px; margin-top: 20px; padding-top: 20px; border-top: 1px solid #ddd; }
    .location-editor { background: #fff; border: 1px solid #e8e8e8; border-radius: 10px; padding: 12px; margin-bottom: 14px; }
    .map-pin-actions { display: flex; gap: 8px; margin-bottom: 8px; }
    .map-pin-status { font-size: 0.85rem; color: var(--color-text-muted); margin-bottom: 8px; }
    .map-pin-canvas { height: 210px; border-radius: 8px; overflow: hidden; border: 1px solid #ddd; margin-bottom: 8px; }
    .map-pin-btn { padding: 8px 12px; border: none; border-radius: 8px; font-weight: 700; color: #fff; cursor: pointer; }
    .map-pin-btn.primary { background: #2563eb; }
    .map-pin-btn.secondary { background: #6b7280; }
    
    .btn-save { background: var(--color-primary); color: #fff; }
    .btn-delete { background: #dc3545; color: #fff; }
    .btn-cancel { background: transparent; color: #666; border: 1px solid #ccc; }

    .toast-msg {
        position: fixed; top: 90px; right: 20px; padding: 16px 28px; border-radius: 10px; color: #fff; font-weight: 600; z-index: 5600; opacity: 0; transform: translateX(40px); transition: all 0.4s;
    }
    .toast-msg.show { opacity: 1; transform: translateX(0); }
    .toast-msg.success { background: #198754; }
    .toast-msg.error { background: #dc3545; }
    
    .empty-state { text-align: center; padding: 60px 20px; background: #fff; border-radius: 12px; }
    .empty-state i { font-size: 4rem; color: #ccc; margin-bottom: 15px; }
</style>

<div class="manage-page-wrapper">
    <div class="container">
        <div class="manage-header">
            <div>
                <h2>Quản lý bài đăng</h2>
                <p>Xem, chỉnh sửa hoặc xóa bài đã đăng.</p>
            </div>
            <div>
                <a href="/Home/PostRoom" class="btn btn-primary fw-bold" id="btn-post-new" style="background: var(--color-primary); border: none; display:none;">
                    <i class="fas fa-plus me-1"></i> Đăng bài mới
                </a>
            </div>
        </div>

        <div class="manage-toolbar">
            <input type="text" id="searchInput" placeholder="Tìm kiếm theo tiêu đề...">
            <select id="statusFilter">
                <option value="">Tất cả trạng thái</option>
            </select>
        </div>

        <div id="manageResults">
            <div class="text-center py-5"><i class="fas fa-spinner fa-spin fa-2x text-muted"></i></div>
        </div>
    </div>
</div>

<div class="toast-msg" id="toastMsg"></div>

<!-- Confirm Delete Modal -->
<div class="modal fade" id="deleteModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title fw-bold">Xóa bài đăng này?</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body">
        Hành động này không thể hoàn tác. Bạn có chắc chắn muốn xóa bài đăng này không?
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy</button>
        <button type="button" class="btn btn-danger" id="confirmDeleteBtn">Xóa bài đăng</button>
      </div>
    </div>
  </div>
</div>

<!-- Template Form Sửa Phòng Trọ -->
<template id="tpl-edit-room">
    <form class="edit-form" data-type="room">
        <input type="hidden" name="OriginalLocationId" value="0">
        <div class="form-row">
            <div>
                <label class="form-label-custom">Danh mục</label>
                <select name="CategoryId" class="form-input" required>
                    <option value="">— Chọn danh mục —</option>
                </select>
            </div>
            <div>
                <label class="form-label-custom">Tỉnh/Thành phố</label>
                <select name="ProvinceCode" class="form-input js-province-select">
                    <option value="">— Chọn tỉnh/thành —</option>
                </select>
            </div>
        </div>
        <div class="form-row">
            <div>
                <label class="form-label-custom">Quận/Huyện</label>
                <select name="DistrictCode" class="form-input js-district-select" disabled>
                    <option value="">— Chọn quận/huyện —</option>
                </select>
            </div>
            <div>
                <label class="form-label-custom">Phường/Xã</label>
                <select name="WardCode" class="form-input js-ward-select" disabled>
                    <option value="">— Chọn phường/xã —</option>
                </select>
            </div>
        </div>
        <div class="form-row">
            <div>
                <label class="form-label-custom">Số nhà</label>
                <input type="text" name="HouseNumber" class="form-input" placeholder="VD: 25/7A">
            </div>
            <div>
                <label class="form-label-custom">Đường</label>
                <input type="text" name="Street" class="form-input" placeholder="VD: Nguyễn Trãi">
            </div>
        </div>
        <div class="location-editor">
            <label class="form-label-custom">Ghim vị trí bản đồ</label>
            <div class="map-pin-actions">
                <button type="button" class="map-pin-btn primary js-geocode-btn">Ghim từ địa chỉ</button>
                <button type="button" class="map-pin-btn primary js-gps-btn">Lấy vị trí của tôi</button>
                <button type="button" class="map-pin-btn secondary js-reset-pin-btn">Đặt lại ghim</button>
            </div>
            <div class="map-pin-status js-map-status">Chưa có vị trí. Hãy chọn địa chỉ và ghim vị trí.</div>
            <div class="map-pin-canvas js-map-canvas"></div>
            <div class="form-row" style="margin-top: 10px; margin-bottom: 0;">
                <div>
                    <label class="form-label-custom">Latitude</label>
                    <input type="text" name="Latitude" class="form-input js-lat-input" readonly>
                </div>
                <div>
                    <label class="form-label-custom">Longitude</label>
                    <input type="text" name="Longitude" class="form-input js-lng-input" readonly>
                </div>
            </div>
        </div>
        <label class="form-label-custom">Tiêu đề</label>
        <input type="text" name="Title" class="form-input" required maxlength="255">
        <div class="form-row">
            <div>
                <label class="form-label-custom">Giá thuê (VNĐ)</label>
                <input type="number" name="Price" class="form-input" required>
            </div>
            <div>
                <label class="form-label-custom">Diện tích (m²)</label>
                <input type="number" name="Area" class="form-input" required>
            </div>
        </div>
        <div class="form-row">
            <div>
                <label class="form-label-custom">Điện thoại</label>
                <input type="tel" name="ContactPhone" class="form-input" maxlength="20">
            </div>
            <div>
                <label class="form-label-custom">Trạng thái</label>
                <select name="RoomStatus" class="form-input">
                    <option value="Available">Còn trống</option>
                    <option value="Rented">Đã cho thuê</option>
                </select>
            </div>
        </div>
        <label class="form-label-custom">Mô tả</label>
        <textarea name="Description" class="form-input" rows="3"></textarea>
        
        <div class="action-bar">
            <button type="button" class="btn-action btn-delete js-action-btn" data-action="askDelete">Xóa bài đăng</button>
            <button type="button" class="btn-action btn-cancel js-action-btn" data-action="closeEdit">Hủy</button>
            <button type="submit" class="btn-action btn-save">Lưu chỉnh sửa</button>
        </div>
    </form>
</template>

